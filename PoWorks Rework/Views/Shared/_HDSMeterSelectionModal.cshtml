@model PoWorks_Rework.Models.HDSMeterSelectionViewModel

<!-- HDS Meter Selection Modal -->
<div class="modal fade" id="hdsMeterSelectionModal" tabindex="-1" aria-labelledby="hdsMeterSelectionModalLabel" aria-hidden="true" data-table-name="@Model.TableName">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="hdsMeterSelectionModalLabel">
                    Select Meters to Import from @Model.TableName
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="d-flex align-items-center">
                            <h6 class="mb-0 me-3">Available Meters</h6>
                            <span id="selectionStatus" class="badge bg-primary">Selected 0 of @Model.HdsMeters.Count meters</span>
                        </div>
                        <div>
                            <button type="button" id="selectAllBtn" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-check-all"></i> Select All
                            </button>
                            <button type="button" id="deselectAllBtn" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-x-lg"></i> Deselect All
                            </button>
                        </div>
                    </div>

                    <!-- Filter -->
                    <div class="input-group mb-3">
                        <span class="input-group-text">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" class="form-control" id="filterInput" placeholder="Filter meters by name...">
                        <span class="input-group-text" id="filterStatus">
                            Showing @Model.HdsMeters.Count of @Model.HdsMeters.Count meters
                        </span>
                    </div>

                    <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-bordered table-hover" id="hdsMeterTable">
                            <thead class="sticky-top bg-light">
                                <tr>
                                    <th style="width: 50px;" class="text-center">Import</th>
                                    <th>HDS Meter Name</th>
                                    <th>Unit</th>
                                    <th>Parent Meter</th>
                                    <th style="width: 80px;">Type</th>
                                    <th style="width: 80px;">Active</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.HdsMeters != null && Model.HdsMeters.Any())
                                {
                                    @for (int i = 0; i < Model.HdsMeters.Count; i++)
                                    {
                                        var meter = Model.HdsMeters[i];
                                        <tr>
                                            <td class="text-center">
                                                <div class="form-check d-flex justify-content-center">
                                                    <input class="form-check-input meter-checkbox" type="checkbox"
                                                           id="meter_@i" name="SelectedMeters[@i].IsSelected" value="true" checked>
                                                    <input type="hidden" name="SelectedMeters[@i].IsSelected" value="false">
                                                    <input type="hidden" name="SelectedMeters[@i].HdsMeterName" value="@meter.HdsMeterName" />
                                                </div>
                                            </td>
                                            <td>@meter.HdsMeterName</td>
                                            <td>
                                                <input type="text" class="form-control form-control-sm"
                                                       name="SelectedMeters[@i].Unit" value="@meter.Unit">
                                            </td>
                                            <td>
                                                <select class="form-select form-select-sm" name="SelectedMeters[@i].ParentMeterId">
                                                    <option value="">None</option>
                                                    @foreach (var parentOption in Model.ParentMeterOptions)
                                                    {
                                                        if (parentOption.Value == meter.ParentMeterId)
                                                        {
                                                            <option value="@parentOption.Value" selected>@parentOption.Text</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@parentOption.Value">@parentOption.Text</option>
                                                        }
                                                    }
                                                </select>
                                            </td>
                                            <td>
                                                <select class="form-select form-select-sm" name="SelectedMeters[@i].Type">
                                                    @if (meter.Type?.ToLower() == "sub")
                                                    {
                                                        <option value="Main">Main</option>
                                                        <option value="Sub" selected>Sub</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="Main" selected>Main</option>
                                                        <option value="Sub">Sub</option>
                                                    }
                                                </select>
                                            </td>
                                            <td class="text-center">
                                                <div class="form-check d-flex justify-content-center">
                                                    @if (meter.Active)
                                                    {
                                                        <input class="form-check-input" type="checkbox"
                                                               id="active_@i" name="SelectedMeters[@i].Active" checked>
                                                    }
                                                    else
                                                    {
                                                        <input class="form-check-input" type="checkbox"
                                                               id="active_@i" name="SelectedMeters[@i].Active">
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center">No meters found in the selected HDS table.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Bulk Operations Controls -->
                <div class="alert alert-info">
                    <strong>Tip:</strong> You can set common properties for all selected meters using the controls below.
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="card">
                            <div class="card-header bg-light">Bulk Set Type</div>
                            <div class="card-body">
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="radio" name="bulkType" id="bulkTypeMain" value="Main">
                                    <label class="form-check-label" for="bulkTypeMain">Main</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="bulkType" id="bulkTypeSub" value="Sub">
                                    <label class="form-check-label" for="bulkTypeSub">Sub</label>
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-primary mt-2" id="applyBulkType">Apply Type</button>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card">
                            <div class="card-header bg-light">Bulk Set Parent</div>
                            <div class="card-body">
                                <select class="form-select mb-2" id="bulkParent">
                                    <option value="">None</option>
                                    @foreach (var parentOption in Model?.ParentMeterOptions ?? new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
                                    {
                                        <option value="@parentOption.Value">@parentOption.Text</option>
                                    }
                                </select>
                                <button type="button" class="btn btn-sm btn-outline-primary" id="applyBulkParent">Apply Parent</button>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card">
                            <div class="card-header bg-light">Bulk Set Active Status</div>
                            <div class="card-body">
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" id="bulkActive" value="true" checked>
                                    <label class="form-check-label" for="bulkActive">Active</label>
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-primary" id="applyBulkActive">Apply Status</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Import Options -->
                <div class="card mt-3">
                    <div class="card-header bg-light">
                        <h6 class="mb-0">Import Options</h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" id="skipExisting" value="true" checked>
                                    <label class="form-check-label" for="skipExisting">
                                        Skip existing meters (based on name)
                                    </label>
                                </div>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" id="updateExisting" value="true">
                                    <label class="form-check-label" for="updateExisting">
                                        Update existing meters instead of skipping
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="createMissingParents" value="true" checked>
                                    <label class="form-check-label" for="createMissingParents">
                                        Create missing parent meters automatically
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" id="importReadings" value="true" checked>
                                    <label class="form-check-label" for="importReadings">
                                        Import historical readings for selected meters
                                    </label>
                                </div>
                                <div class="form-group mb-2">
                                    <div class="row g-2">
                                        <div class="col-6">
                                            <label for="readingsStartDate" class="form-label small">Start Date</label>
                                            <input type="date" class="form-control form-control-sm" id="readingsStartDate">
                                        </div>
                                        <div class="col-6">
                                            <label for="readingsEndDate" class="form-label small">End Date</label>
                                            <input type="date" class="form-control form-control-sm" id="readingsEndDate">
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="readingsLimit" class="form-label small">Maximum readings per meter</label>
                                    <input type="number" class="form-control form-control-sm" id="readingsLimit" value="1000" min="1" max="10000">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <div id="meterImportProgressContainer" class="w-100 d-none">
                    <div class="progress mb-2">
                        <div id="meterImportProgressBar" class="progress-bar" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">0%</div>
                    </div>
                    <div id="meterImportStatus" class="text-center mb-2">Ready to import meters</div>
                </div>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="importSelectedBtn">Import Selected</button>
            </div>
        </div>
    </div>
</div>

<script>
    // Initialize date pickers when modal is shown
    document.addEventListener('DOMContentLoaded', function() {
        // Set default date range (past 30 days)
        const today = new Date();
        const oneMonthAgo = new Date();
        oneMonthAgo.setMonth(today.getMonth() - 1);

        // Format dates to YYYY-MM-DD
        const endDateStr = today.toISOString().split('T')[0];
        const startDateStr = oneMonthAgo.toISOString().split('T')[0];

        // Set the date values
        const startDateInput = document.getElementById('readingsStartDate');
        const endDateInput = document.getElementById('readingsEndDate');

        if (startDateInput) startDateInput.value = startDateStr;
        if (endDateInput) endDateInput.value = endDateStr;

        // Link skipExisting and updateExisting checkboxes
        const skipExistingCheck = document.getElementById('skipExisting');
        const updateExistingCheck = document.getElementById('updateExisting');

        if (skipExistingCheck && updateExistingCheck) {
            updateExistingCheck.addEventListener('change', function() {
                if (this.checked) {
                    skipExistingCheck.checked = true;
                    skipExistingCheck.disabled = true;
                } else {
                    skipExistingCheck.disabled = false;
                }
            });
        }

        // Toggle readings date and limit fields based on importReadings checkbox
        const importReadingsCheck = document.getElementById('importReadings');
        const readingsDateControls = document.querySelectorAll('#readingsStartDate, #readingsEndDate, #readingsLimit');

        if (importReadingsCheck && readingsDateControls.length > 0) {
            importReadingsCheck.addEventListener('change', function() {
                readingsDateControls.forEach(control => {
                    control.disabled = !this.checked;
                });
            });
        }
    });
</script>