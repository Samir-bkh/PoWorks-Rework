@model PoWorks_Rework.Models.HDSMeterSelectionViewModel

<!-- HDS Meter Selection Modal -->
<div class="modal fade" id="hdsMeterSelectionModal" tabindex="-1" aria-labelledby="hdsMeterSelectionModalLabel" aria-hidden="true" data-table-name="@Model.TableName">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="hdsMeterSelectionModalLabel">
                    Select Meters to Import from @Model.TableName
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="d-flex align-items-center">
                            <h6 class="mb-0 me-3">Available Meters</h6>
                            <span id="selectionStatus" class="badge bg-primary">Selected 0 of @Model.HdsMeters.Count meters</span>
                        </div>
                        <div>
                            <button type="button" id="selectAllBtn" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-check-all"></i> Select All
                            </button>
                            <button type="button" id="deselectAllBtn" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-x-lg"></i> Deselect All
                            </button>
                        </div>
                    </div>

                    <!-- Filter -->
                    <div class="input-group mb-3">
                        <span class="input-group-text">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" class="form-control" id="filterInput" placeholder="Filter meters by name...">
                        <span class="input-group-text" id="filterStatus">
                            Showing @Model.HdsMeters.Count of @Model.HdsMeters.Count meters
                        </span>
                    </div>

                    <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-bordered table-hover" id="hdsMeterTable">
                            <thead class="sticky-top bg-light">
                                <tr>
                                    <th style="width: 50px;" class="text-center">Import</th>
                                    <th>HDS Meter Name</th>
                                    <th>Unit</th>
                                    <th>Parent Meter</th>
                                    <th style="width: 80px;">Type</th>
                                    <th style="width: 80px;">Active</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.HdsMeters != null && Model.HdsMeters.Any())
                                {
                                    @for (int i = 0; i < Model.HdsMeters.Count; i++)
                                    {
                                        var meter = Model.HdsMeters[i];
                                        <tr>
                                            <td class="text-center">
                                                <div class="form-check d-flex justify-content-center">
                                                    <input class="form-check-input meter-checkbox" type="checkbox"
                                                           id="meter_@i" name="SelectedMeters[@i].IsSelected" value="true" checked>
                                                    <input type="hidden" name="SelectedMeters[@i].IsSelected" value="false">
                                                    <input type="hidden" name="SelectedMeters[@i].HdsMeterName" value="@meter.HdsMeterName" />
                                                </div>
                                            </td>
                                            <td>@meter.HdsMeterName</td>
                                            <td>
                                                <input type="text" class="form-control form-control-sm"
                                                       name="SelectedMeters[@i].Unit" value="@meter.Unit">
                                            </td>
                                            <td>
                                                <select class="form-select form-select-sm" name="SelectedMeters[@i].ParentMeterId">
                                                    <option value="">None</option>
                                                    @foreach (var parentOption in Model.ParentMeterOptions)
                                                    {
                                                        if (parentOption.Value == meter.ParentMeterId)
                                                        {
                                                            <option value="@parentOption.Value" selected>@parentOption.Text</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@parentOption.Value">@parentOption.Text</option>
                                                        }
                                                    }
                                                </select>
                                            </td>
                                            <td>
                                                <select class="form-select form-select-sm" name="SelectedMeters[@i].Type">
                                                    @if (meter.Type?.ToLower() == "sub")
                                                    {
                                                        <option value="Main">Main</option>
                                                        <option value="Sub" selected>Sub</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="Main" selected>Main</option>
                                                        <option value="Sub">Sub</option>
                                                    }
                                                </select>
                                            </td>
                                            <td class="text-center">
                                                <div class="form-check d-flex justify-content-center">
                                                    @if (meter.Active)
                                                    {
                                                        <input class="form-check-input" type="checkbox"
                                                               id="active_@i" name="SelectedMeters[@i].Active" checked>
                                                    }
                                                    else
                                                    {
                                                        <input class="form-check-input" type="checkbox"
                                                               id="active_@i" name="SelectedMeters[@i].Active">
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center">No meters found in the selected HDS table.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

              
                <!-- Add this inside the HDS meter selection modal -->
                <form id="hdsImportForm" asp-controller="HdsImport" asp-action="ImportMeters" method="post">
                    <!-- Hidden inputs for selected meters will be added dynamically -->
                    <input type="hidden" name="tableName" id="hiddenTableName" />
                    <input type="hidden" name="skipExisting" id="hiddenSkipExisting" />
                    <input type="hidden" name="updateExisting" id="hiddenUpdateExisting" />
                    <input type="hidden" name="createMissingParents" id="hiddenCreateMissingParents" />
                    <!-- Other hidden inputs for import options -->
                </form>

              
            <div class="modal-footer">
                <div id="meterImportProgressContainer" class="w-100 d-none">
                    <div class="progress mb-2">
                        <div id="meterImportProgressBar" class="progress-bar" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">0%</div>
                    </div>
                    <div id="meterImportStatus" class="text-center mb-2">Ready to import meters</div>
                </div>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <!-- Replace the existing button with this: -->
                <!-- Replace the existing import button with this small form -->
                <form action="/HdsImport/PrintSelectedMeters" method="post" target="print-frame">
                    <!-- Table name -->
                    <input type="hidden" name="tableName" value="@Model.TableName" />

                    <!-- Add a simple list of selected meter IDs -->
                    <div id="selected-meters-container">
                        <!-- This will be filled dynamically by JavaScript -->
                    </div>

                    <!-- Simple submit button -->
                    <button type="submit" class="btn btn-success" id="print-button">Print Selected Data</button>
                </form>

                <!-- Add a hidden iframe to target the form submission -->
                <iframe name="print-frame" style="display:none;"></iframe>

            </div>
        </div>
    </div>
</div>
</div>

// Add this script directly in the _HDSMeterSelectionModal.cshtml file

<script>
    // When a checkbox is checked/unchecked, update the corresponding hidden input
    document.addEventListener('DOMContentLoaded', function() {
        const checkboxes = document.querySelectorAll('.meter-checkbox');

        // Set initial states based on checkboxes
        checkboxes.forEach(function(checkbox) {
            const index = checkbox.id.split('_')[1];
            if (!index) return;

            const selectedInput = document.querySelector(`.meter-data-container[data-index="${index}"] .meter-selected-input`);
            if (selectedInput) {
                selectedInput.value = checkbox.checked ? "true" : "false";
            }
        });

        // Add change listeners to checkboxes
        checkboxes.forEach(function(checkbox) {
            checkbox.addEventListener('change', function() {
                const index = this.id.split('_')[1];
                if (!index) return;

                const selectedInput = document.querySelector(`.meter-data-container[data-index="${index}"] .meter-selected-input`);
                if (selectedInput) {
                    selectedInput.value = this.checked ? "true" : "false";
                }
            });
        });

        // Add click handler for the print button
        document.getElementById('print-button').addEventListener('click', function() {
            // Update all selected inputs based on current checkbox states
            checkboxes.forEach(function(checkbox) {
                const index = checkbox.id.split('_')[1];
                if (!index) return;

                const selectedInput = document.querySelector(`.meter-data-container[data-index="${index}"] .meter-selected-input`);
                if (selectedInput) {
                    selectedInput.value = checkbox.checked ? "true" : "false";
                }
            });

            // Show feedback that data is being sent
            alert('Printing selected meters data to terminal...');
        });
    });
</script>