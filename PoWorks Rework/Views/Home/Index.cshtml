@{
    ViewData["Title"] = "Energy Consumption Dashboard";
    Layout = "_Layout";
}

<div class="container-fluid mt-4">
    <!-- Warning Message -->
    @if (TempData["WarningMessage"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            @TempData["WarningMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-12">
            <h2>Energy Consumption Analytics</h2>
        </div>
    </div>

    <!-- Filters Section -->
    <div class="row mt-3">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Filters</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <!-- Date Filter -->
                        <div class="col-md-2 d-none">
                            <div class="form-group">
                                <label for="dateFilter">Date Range</label>
                                <select id="dateFilter" class="form-control">
                                    <option value="daily">Daily</option>
                                    <option value="monthly" selected>Monthly</option>
                                    <option value="yearly">Yearly</option>
                                </select>
                            </div>
                        </div>

                        <!-- Tenant Filter (Optional) -->
                        <div class="col-md-2">
                            <div class="form-group">
                                <label for="tenantFilter">Tenant (Optional)</label>
                                <select id="tenantFilter" class="form-control">
                                    <option value="">All Tenants</option>
                                </select>
                            </div>
                        </div>

                        <!-- Meter Filter (Now Independent) -->
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="meterFilter">Meter</label>
                                <div class="input-group">
                                    <select id="meterFilter" class="form-control">
                                        <option value="">All Meters (Loading...)</option>
                                    </select>
                                    <button id="loadMoreMeters" class="btn btn-outline-secondary" type="button" style="display: none;">
                                        Load More
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- NEW: Meter Limit Control -->
                        <div class="col-md-2">
                            <div class="form-group">
                                <label for="meterLimit">Meter Limit</label>
                                <select id="meterLimit" class="form-control">
                                    <option value="5" selected>5 meters</option>
                                    <option value="10">10 meters</option>
                                    <option value="25">25 meters</option>
                                    <option value="50">50 meters</option>
                                    <option value="100">100 meters</option>
                                </select>
                            </div>
                        </div>

                        <!-- Chart Type -->
                        <div class="col-md-2">
                            <div class="form-group">
                                <label for="chartType">Chart Type</label>
                                <select id="chartType" class="form-control">
                                    <option value="bar">Bar Chart</option>
                                    <option value="line">Line Chart</option>
                                </select>
                            </div>
                        </div>

                        <!-- NEW: Quick Actions -->
                        <div class="col-md-1">
                            <div class="form-group">
                                <label>&nbsp;</label>
                                <div class="d-flex flex-column">
                                    <button id="refreshMeters" class="btn btn-sm btn-outline-info mb-1" title="Refresh Meter List">
                                        <i class="bi bi-arrow-clockwise"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="dateRange">Date Range</label>
                                <div class="input-group">
                                    <input type="date" id="startDate" class="form-control" />
                                    <div class="input-group-text">to</div>
                                    <input type="date" id="endDate" class="form-control" />
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <button id="applyFilters" class="btn btn-primary mr-2">Apply Filters</button>
                            <button id="resetFilters" class="btn btn-secondary">Reset</button>
                        </div>
                    </div>

                    <!-- NEW: Data Status Information -->
                    <div class="row mt-2">
                        <div class="col-12">
                            <div id="dataStatus" class="alert alert-info" style="display: none;">
                                <small id="dataStatusText">Loading meter information...</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Chart Section -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div class="d-flex align-items-center gap-3">
                        <h5 class="mb-0">Energy Consumption</h5>
                        
                        <div class="btn-group btn-group-sm" role="group" aria-label="Mode d'affichage">
                            <input type="radio" class="btn-check" name="viewMode" id="modeStandard" value="standard" autocomplete="off" checked>
                            <label class="btn btn-outline-primary" for="modeStandard"><i class="bi bi-graph-up"></i> Standard</label>

                            <input type="radio" class="btn-check" name="viewMode" id="modeComparison" value="comparison" autocomplete="off">
                            <label class="btn btn-outline-primary" for="modeComparison"><i class="bi bi-layers"></i> Comparaison</label>
                        </div>
                    </div>
                    
                    <div class="btn-group btn-group-sm" role="group">
                        <button id="resetZoomBtn" class="btn btn-outline-secondary" type="button" title="Réinitialiser le zoom">
                            <i class="bi bi-arrows-angle-expand"></i> Zoom
                        </button>
                        <button id="autoRefresh" class="btn btn-outline-secondary" type="button" title="Auto Refresh (30s)">
                            <i class="bi bi-arrow-repeat"></i>
                        </button>
                        <button id="exportChart" class="btn btn-outline-secondary" type="button" title="Export Chart">
                            <i class="bi bi-download"></i>
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    
                    <!-- LES ONGLETS SONT BIEN PLACÉS ICI -->
                    <div class="row mb-3">
                        <div class="col-12 d-flex justify-content-center">
                            <div class="btn-group shadow-sm" role="group">
                                <button type="button" class="btn btn-outline-primary active" id="tabDaily" style="min-width: 150px; font-weight: bold;">JOURNALIER</button>
                                <button type="button" class="btn btn-outline-primary" id="tabMonthly" style="min-width: 150px; font-weight: bold;">MENSUEL</button>
                                <button type="button" class="btn btn-outline-primary" id="tabYearly" style="min-width: 150px; font-weight: bold;">ANNUEL</button>
                            </div>
                        </div>
                    </div>
                    
                    <div id="loadingSpinner" class="text-center d-none">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="mt-2 text-muted">Loading chart data...</p>
                    </div>
                    
                    <canvas id="consumptionChart" style="max-height: 400px;"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">


                    <h5 id="topConsumersTitle" class="mb-0 text-danger"><i class="bi bi-fire"></i> Top 5 des compteurs (Vue Globale)</h5>
                </div>
                <div class="card-body">
                    <div id="topConsumersList">
                        <p class="text-muted text-center">Chargement du classement...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary Cards (DESIGN MODERNE) -->
    <div class="row mt-4">
        <!-- Carte 1 : Total Consumption -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted fw-normal mb-2">Total Consumption</h6>
                            <h4 class="mb-0 fw-bold text-dark" id="totalConsumption">0 kWh</h4>
                            <small id="totalConsumptionDetail" class="text-muted mt-1 d-block"></small>
                        </div>
                        <div class="bg-primary bg-opacity-10 p-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                            <i class="bi bi-lightning-charge-fill text-primary fs-5"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Carte 2 : Average Daily -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted fw-normal mb-2">Average Daily</h6>
                            <h4 class="mb-0 fw-bold text-dark" id="avgDaily">0 kWh</h4>
                            <small id="avgDailyDetail" class="text-muted mt-1 d-block">Per day average</small>
                        </div>
                        <div class="bg-success bg-opacity-10 p-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                            <i class="bi bi-calendar-event-fill text-success fs-5"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Carte 3 : Peak Usage -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted fw-normal mb-2">Peak Usage</h6>
                            <h4 class="mb-0 fw-bold text-dark" id="peakUsage">0 kWh</h4>
                            <small id="peakUsageDetail" class="text-muted mt-1 d-block">Maximum recorded</small>
                        </div>
                        <div class="bg-warning bg-opacity-10 p-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                            <i class="bi bi-graph-up-arrow text-warning fs-5"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Carte 4 : Active Meters -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted fw-normal mb-2">Active Meters</h6>
                            <h4 class="mb-0 fw-bold text-dark" id="activeMeters">0</h4>
                            <small id="activeMetersDetail" class="text-muted mt-1 d-block">Out of total available</small>
                        </div>
                        <div class="bg-info bg-opacity-10 p-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                            <i class="bi bi-speedometer2 text-info fs-5"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/hammer.js/2.0.8/hammer.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom@2.0.1/dist/chartjs-plugin-zoom.min.js"></script>
    <script src="~/js/energy-dashboard.js"></script>
}