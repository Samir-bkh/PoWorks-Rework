@model PoWorks_Rework.Models.BillsViewModel
@{
    ViewData["Title"] = "Bills";
}

<div class="card">
    <div class="card-header">
        <h4>Bills</h4>
    </div>
    <div class="card-body">
        <!-- Status Messages -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <!-- Search Area -->
        <form asp-action="Search" asp-controller="Bills" method="post">
            <div class="row mb-4">
                <div class="col-md-8">
                    <div class="mb-3 row">
                        <label for="searchCriteria" class="col-sm-3 col-form-label">Search Criteria</label>
                        <div class="col-sm-9">
                            <select class="form-select" id="searchCriteria" name="searchCriteria" onchange="updateSearchOptions()">
                                <option value="Meter Name" selected="@(Model.SearchCriteria == "Meter Name")">Meter Name</option>
                                <option value="Tenant" selected="@(Model.SearchCriteria == "Tenant")">Tenant</option>
                                <option value="Bill Date" selected="@(Model.SearchCriteria == "Bill Date")">Bill Date</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3 row">
                        <label for="searchTerm" class="col-sm-3 col-form-label">Search Term</label>
                        <div class="col-sm-9">
                            <!-- Container for dynamic search inputs -->
                            <div id="searchTermContainer">
                                <!-- Default search input is a select for Meter Name -->
                                <select class="form-select" id="meterSelect" name="searchTerm" style="display: @(Model.SearchCriteria == "Meter Name" ? "block" : "none");">
                                    <option value="">All Meters</option>
                                    @foreach (var meter in Model.MeterOptions)
                                    {
                                        <option value="@meter.Text" selected="@(Model.SearchTerm == meter.Text)">@meter.Text</option>
                                    }
                                </select>

                                <!-- Tenant select (hidden by default) -->
                                <select class="form-select" id="tenantSelect" name="searchTerm" style="display: @(Model.SearchCriteria == "Tenant" ? "block" : "none");">
                                    <option value="">All Tenants</option>
                                    @foreach (var tenant in Model.TenantOptions)
                                    {
                                        <option value="@tenant.Text" selected="@(Model.SearchTerm == tenant.Text)">@tenant.Text</option>
                                    }
                                </select>

                                <!-- Date input (hidden by default) -->
                                <input type="date" class="form-control" id="dateInput" name="searchTerm" value="@Model.SearchTerm" style="display: @(Model.SearchCriteria == "Bill Date" ? "block" : "none");">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 d-flex align-items-end justify-content-end">
                    <button type="submit" class="btn btn-primary">Search</button>
                </div>
            </div>
        </form>

        <!-- Search Results -->
        <div class="card mb-3">
            <div class="card-header bg-light">
                <h5 class="mb-0">Search Results</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Tenant</th>
                                <th>Meter</th>
                                <th>Bill Date</th>
                                <th>Total Consumption</th>
                                <th>Net Total (RM)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.SearchResults != null && Model.SearchResults.Any())
                            {
                                @foreach (var bill in Model.SearchResults)
                                {
                                    <tr>
                                        <td>@bill.Tenant</td>
                                        <td>@bill.Meter</td>
                                        <td>@bill.BillDate</td>
                                        <td>@bill.TotalConsumption</td>
                                        <td>@bill.NetTotal.ToString("N2")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center">No bills found matching your search criteria.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (Model.TotalPages > 1)
                {
                    <div class="d-flex justify-content-between align-items-center p-2 bg-light border-top">
                        <div>
                            <nav aria-label="Page navigation">
                                <ul class="pagination mb-0">
                                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                        <a class="page-link" href="@Url.Action("Search", "Bills", new { searchCriteria = Model.SearchCriteria, searchTerm = Model.SearchTerm, page = 1 })" aria-label="First">
                                            <span aria-hidden="true">&laquo;</span>
                                        </a>
                                    </li>
                                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                        <a class="page-link" href="@Url.Action("Search", "Bills", new { searchCriteria = Model.SearchCriteria, searchTerm = Model.SearchTerm, page = Math.Max(1, Model.CurrentPage - 1) })" aria-label="Previous">
                                            <span aria-hidden="true">&lsaquo;</span>
                                        </a>
                                    </li>

                                    @{
                                        int startPage = Math.Max(1, Model.CurrentPage - 2);
                                        int endPage = Math.Min(Model.TotalPages, startPage + 4);
                                    }

                                    @for (int i = startPage; i <= endPage; i++)
                                    {
                                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                            <a class="page-link" href="@Url.Action("Search", "Bills", new { searchCriteria = Model.SearchCriteria, searchTerm = Model.SearchTerm, page = i })">@i</a>
                                        </li>
                                    }

                                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                        <a class="page-link" href="@Url.Action("Search", "Bills", new { searchCriteria = Model.SearchCriteria, searchTerm = Model.SearchTerm, page = Math.Min(Model.TotalPages, Model.CurrentPage + 1) })" aria-label="Next">
                                            <span aria-hidden="true">&rsaquo;</span>
                                        </a>
                                    </li>
                                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                        <a class="page-link" href="@Url.Action("Search", "Bills", new { searchCriteria = Model.SearchCriteria, searchTerm = Model.SearchTerm, page = Model.TotalPages })" aria-label="Last">
                                            <span aria-hidden="true">&raquo;</span>
                                        </a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                        <div>
                            <span class="text-muted">@Model.CurrentPage of @Model.TotalPages pages (@Model.TotalItems items)</span>
                        </div>
                    </div>
                }
                else if (Model.SearchResults != null && Model.SearchResults.Any())
                {
                    <div class="d-flex justify-content-end align-items-center p-2 bg-light border-top">
                        <span class="text-muted">@Model.TotalItems @(Model.TotalItems == 1 ? "item" : "items")</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateSearchOptions() {
            const criteria = document.getElementById('searchCriteria').value;

            // Hide all search inputs
            document.getElementById('meterSelect').style.display = 'none';
            document.getElementById('tenantSelect').style.display = 'none';
            document.getElementById('dateInput').style.display = 'none';

            // Show the appropriate search input based on selected criteria
            if (criteria === 'Meter Name') {
                document.getElementById('meterSelect').style.display = 'block';
                document.getElementById('meterSelect').name = 'searchTerm';
            } else if (criteria === 'Tenant') {
                document.getElementById('tenantSelect').style.display = 'block';
                document.getElementById('tenantSelect').name = 'searchTerm';
            } else if (criteria === 'Bill Date') {
                document.getElementById('dateInput').style.display = 'block';
                document.getElementById('dateInput').name = 'searchTerm';
            }
        }

        // Initialize the form on page load
        document.addEventListener('DOMContentLoaded', function() {
            updateSearchOptions();
        });
    </script>
}