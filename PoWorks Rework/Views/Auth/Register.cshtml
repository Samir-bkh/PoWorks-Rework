@model Microsoft.AspNetCore.Identity.IdentityUser
@{
    ViewData["Title"] = "Créer un compte administrateur";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PoWorks</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background-color: #f8f9fa; }
        .auth-container { max-width: 400px; margin: 5rem auto; }
        .auth-card { padding: 2rem; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); background: white; }
    </style>
</head>
<body>
    <div class="container auth-container">
        <div class="auth-card">
            <div class="text-center mb-4">
                <i class="fas fa-bolt text-primary fa-3x mb-3"></i>
                <h4>Création de compte</h4>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @Html.ValidationSummary(string.Empty, new { @class = "mb-0" })
                </div>
            }

            <form asp-controller="Auth" asp-action="Register" method="post">
                <div class="mb-3">
                    <label class="form-label">Nom d'utilisateur</label>
                    <input type="text" name="username" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Mot de passe</label>
                    <input type="password" name="password" class="form-control" required />
                    <div class="form-text text-muted small">Minimum 6 caractères, 1 majuscule, 1 minuscule, 1 chiffre, 1 caractère spécial.</div>
                </div>
                <button type="submit" class="btn btn-primary w-100 mb-3">S'inscrire</button>
            </form>
            
            <div class="text-center">
                <a asp-action="Login" class="text-decoration-none">Déjà un compte ? Se connecter</a>
            </div>
        </div>
    </div>
</body>
</html>