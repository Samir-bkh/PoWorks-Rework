<!-- Views/Meter/_ImportExportModal.cshtml -->

<div class="modal fade" id="importExportModal" tabindex="-1" aria-labelledby="importExportModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="importExportModalLabel">Import / Export Meters</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- Tabs -->
                <ul class="nav nav-tabs" id="importExportTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="import-tab" data-bs-toggle="tab" data-bs-target="#import-tab-pane" type="button" role="tab" aria-controls="import-tab-pane" aria-selected="true">Import</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="export-tab" data-bs-toggle="tab" data-bs-target="#export-tab-pane" type="button" role="tab" aria-controls="export-tab-pane" aria-selected="false">Export</button>
                    </li>
                </ul>

                <!-- Tab Content -->
                <div class="tab-content pt-3" id="importExportTabContent">
                    <!-- Import Tab -->
                    <div class="tab-pane fade show active" id="import-tab-pane" role="tabpanel" aria-labelledby="import-tab" tabindex="0">
                        <div class="mb-4">
                            <h6>Select Import Source</h6>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="card h-100">
                                        <div class="card-body">
                                            <h5 class="card-title">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="radio" name="importSource" id="importSourceCSV" value="csv" checked>
                                                    <label class="form-check-label" for="importSourceCSV">
                                                        CSV File
                                                    </label>
                                                </div>
                                            </h5>
                                            <p class="card-text">Import meters from a CSV file with specific columns.</p>
                                            <div class="mt-3" id="csvImportOptions">
                                                <div class="mb-3">
                                                    <label for="csvFile" class="form-label">Select CSV File</label>
                                                    <input class="form-control" type="file" id="csvFile" accept=".csv">
                                                </div>
                                                <div class="form-check mb-3">
                                                    <input class="form-check-input" type="checkbox" id="csvHasHeaders" checked>
                                                    <label class="form-check-label" for="csvHasHeaders">
                                                        File has headers
                                                    </label>
                                                </div>
                                                <div class="alert alert-info">
                                                    <small>CSV file should contain columns for: Name, Type, ParentName, Unit, LastReading, TenantName, Active</small>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="card h-100">
                                        <div class="card-body">
                                            <h5 class="card-title">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="radio" name="importSource" id="importSourcePCVue" value="pcvue">
                                                    <label class="form-check-label" for="importSourcePCVue">
                                                        PCVue HDS
                                                    </label>
                                                </div>
                                            </h5>
                                            <p class="card-text">Import data from PCVue HDS SQL Server database.</p>
                                            <div class="mt-3" id="pcvueImportOptions" style="display: none;">
                                                <div class="mb-3">
                                                    <label for="pcvueTable" class="form-label">Select HDS Table</label>
                                                    <select class="form-select" id="pcvueTable">
                                                        <option value="">Loading tables...</option>
                                                    </select>
                                                </div>
                                                <div class="mb-3">
                                                    <label for="importDate" class="form-label">Import Date Range</label>
                                                    <div class="row g-2">
                                                        <div class="col-6">
                                                            <input type="date" class="form-control" id="importStartDate">
                                                        </div>
                                                        <div class="col-6">
                                                            <input type="date" class="form-control" id="importEndDate">
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="mb-3">
                                                    <label for="importLimit" class="form-label">Limit records (0 for all)</label>
                                                    <input type="number" class="form-control" id="importLimit" min="0" value="1000">
                                                </div>
                                                <div class="mb-3">
                                                    <button type="button" class="btn btn-primary btn-sm" id="loadMetersBtn">
                                                        <i class="bi bi-list"></i> Select Meters to Import
                                                    </button>
                                                </div>
                                                <div class="alert alert-warning mt-3">
                                                    <small>Please configure SQL Server connection in General Settings before using this option.</small>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <h6>Import Options</h6>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="skipExisting" checked>
                                <label class="form-check-label" for="skipExisting">
                                    Skip existing meters (based on name)
                                </label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="updateExisting">
                                <label class="form-check-label" for="updateExisting">
                                    Update existing meters
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="createMissingTenants">
                                <label class="form-check-label" for="createMissingTenants">
                                    Create missing tenants
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Export Tab -->
                    <div class="tab-pane fade" id="export-tab-pane" role="tabpanel" aria-labelledby="export-tab" tabindex="0">
                        <div class="mb-3">
                            <h6>Export Format</h6>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="exportFormat" id="exportFormatCSV" value="csv" checked>
                                <label class="form-check-label" for="exportFormatCSV">
                                    CSV
                                </label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="exportFormat" id="exportFormatExcel" value="excel">
                                <label class="form-check-label" for="exportFormatExcel">
                                    Excel
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="exportFormat" id="exportFormatJSON" value="json">
                                <label class="form-check-label" for="exportFormatJSON">
                                    JSON
                                </label>
                            </div>
                        </div>

                        <div class="mb-3">
                            <h6>Export Options</h6>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="exportAllMeters" checked>
                                <label class="form-check-label" for="exportAllMeters">
                                    Export all meters
                                </label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="exportActiveOnly">
                                <label class="form-check-label" for="exportActiveOnly">
                                    Export active meters only
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="includeReadings">
                                <label class="form-check-label" for="includeReadings">
                                    Include historical readings
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <div id="importProgressContainer" class="w-100 d-none">
                    <div class="progress mb-2">
                        <div id="importProgressBar" class="progress-bar" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">0%</div>
                    </div>
                    <div id="importStatus" class="text-center mb-2">Ready to import</div>
                </div>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="importExportSubmitBtn">Import</button>
            </div>
        </div>
    </div>
</div>

<!-- Include the HDS Meter Selection Modal -->
<div id="hdsMeterSelectionContainer">
    <!-- This will be dynamically populated by AJAX call -->
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Toggle import options based on selected source
        document.querySelectorAll('input[name="importSource"]').forEach(function(radio) {
            radio.addEventListener('change', function() {
                // Hide all options first
                document.getElementById('csvImportOptions').style.display = 'none';
                document.getElementById('pcvueImportOptions').style.display = 'none';

                // Show the selected option
                if (this.value === 'csv') {
                    document.getElementById('csvImportOptions').style.display = 'block';
                    document.getElementById('importExportSubmitBtn').textContent = 'Import';
                } else if (this.value === 'pcvue') {
                    document.getElementById('pcvueImportOptions').style.display = 'block';
                    document.getElementById('importExportSubmitBtn').textContent = 'Import';

                    // Load PCVue tables when this option is selected
                    loadPCVueTables();
                }
            });
        });

        // Set the button text based on the active tab
        document.querySelectorAll('#importExportTabs button').forEach(function(tab) {
            tab.addEventListener('shown.bs.tab', function() {
                if (this.id === 'import-tab') {
                    document.getElementById('importExportSubmitBtn').textContent = 'Import';
                } else if (this.id === 'export-tab') {
                    document.getElementById('importExportSubmitBtn').textContent = 'Export';
                }
            });
        });

        // Initialize the options visibility
        if (document.getElementById('importSourceCSV').checked) {
            document.getElementById('csvImportOptions').style.display = 'block';
        } else if (document.getElementById('importSourcePCVue').checked) {
            document.getElementById('pcvueImportOptions').style.display = 'block';
        }

        // Function to load PCVue tables
        function loadPCVueTables() {
            // Check if SQL Server connection is configured
            fetch('/HdsImport/GetTables')
                .then(response => {
                    if (!response.ok) {
                        throw new Error('SQL Server connection not configured. Please set up the connection first.');
                    }
                    return response.json();
                })
                .then(tables => {
                    const selectElement = document.getElementById('pcvueTable');
                    selectElement.innerHTML = '';

                    if (tables.length === 0) {
                        const option = document.createElement('option');
                        option.value = '';
                        option.textContent = 'No tables found';
                        selectElement.appendChild(option);
                    } else {
                        const defaultOption = document.createElement('option');
                        defaultOption.value = '';
                        defaultOption.textContent = 'Select a table';
                        selectElement.appendChild(defaultOption);

                        tables.forEach(table => {
                            const option = document.createElement('option');
                            option.value = table;
                            option.textContent = table;
                            selectElement.appendChild(option);
                        });
                    }
                })
                .catch(error => {
                    console.error('Error loading PCVue tables:', error);
                    const selectElement = document.getElementById('pcvueTable');
                    selectElement.innerHTML = '<option value="">Error loading tables</option>';

                    // Show a warning message
                    document.querySelector('#pcvueImportOptions .alert').textContent = error.message;
                });
        }

        // Load Meters Button Click Handler
        document.getElementById('loadMetersBtn').addEventListener('click', function() {
            const tableName = document.getElementById('pcvueTable').value;

            if (!tableName) {
                alert('Please select a table to load meters from.');
                return;
            }

            // Show loading indicator
            this.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Loading...';
            this.disabled = true;

            // Fetch meters from the selected table
            fetch(`/HdsImport/GetMetersFromTable?tableName=${encodeURIComponent(tableName)}`)
                .then(response => {
                    if (!response.ok) {
                        throw new Error(`Failed to load meters: ${response.statusText}`);
                    }
                    return response.text();
                })
                .then(html => {
                    // Insert the meter selection modal into the page
                    document.getElementById('hdsMeterSelectionContainer').innerHTML = html;

                    // Show the modal
                    const hdsMeterSelectionModal = new bootstrap.Modal(document.getElementById('hdsMeterSelectionModal'));
                    hdsMeterSelectionModal.show();

                    // Reset the button
                    this.innerHTML = '<i class="bi bi-list"></i> Select Meters to Import';
                    this.disabled = false;
                })
                .catch(error => {
                    console.error('Error loading meters:', error);
                    alert(`Error loading meters: ${error.message}`);

                    // Reset the button
                    this.innerHTML = '<i class="bi bi-list"></i> Select Meters to Import';
                    this.disabled = false;
                });
        });

        // Import/Export button click handler
        document.getElementById('importExportSubmitBtn').addEventListener('click', function() {
            const activeTabId = document.querySelector('#importExportTabs button.active').id;

            if (activeTabId === 'import-tab') {
                const importSource = document.querySelector('input[name="importSource"]:checked').value;
                if (importSource === 'csv') {
                    handleCsvImport();
                } else if (importSource === 'pcvue') {
                    handlePcvueImport();
                }
            } else if (activeTabId === 'export-tab') {
                handleExport();
            }
        });

        // CSV Import handler
        function handleCsvImport() {
            const fileInput = document.getElementById('csvFile');
            if (!fileInput.files || fileInput.files.length === 0) {
                alert('Please select a CSV file to import.');
                return;
            }

            const file = fileInput.files[0];
            const hasHeaders = document.getElementById('csvHasHeaders').checked;
            const skipExisting = document.getElementById('skipExisting').checked;
            const updateExisting = document.getElementById('updateExisting').checked;
            const createMissingTenants = document.getElementById('createMissingTenants').checked;

            // Create form data
            const formData = new FormData();
            formData.append('file', file);
            formData.append('hasHeaders', hasHeaders);
            formData.append('skipExisting', skipExisting);
            formData.append('updateExisting', updateExisting);
            formData.append('createMissingTenants', createMissingTenants);

            // Show progress
            document.getElementById('importProgressContainer').classList.remove('d-none');
            document.getElementById('importStatus').textContent = 'Importing CSV file...';

            // TODO: Implement the actual import API call
            // This is just a placeholder for now
            alert('CSV import functionality will be implemented in the backend.');
        }

        // PCVue Import handler
        function handlePcvueImport() {
            const table = document.getElementById('pcvueTable').value;
            if (!table) {
                alert('Please select a table to import from PCVue HDS.');
                return;
            }

            // Show the meter selection modal by clicking the load meters button
            document.getElementById('loadMetersBtn').click();
        }

        // Export handler
        function handleExport() {
            const format = document.querySelector('input[name="exportFormat"]:checked').value;
            const exportAllMeters = document.getElementById('exportAllMeters').checked;
            const exportActiveOnly = document.getElementById('exportActiveOnly').checked;
            const includeReadings = document.getElementById('includeReadings').checked;

            // TODO: Implement the actual export API call
            // This is just a placeholder for now
            alert('Export functionality will be implemented in the backend.');
        }
    });
</script>