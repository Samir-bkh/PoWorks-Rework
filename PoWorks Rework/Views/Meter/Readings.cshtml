@model PoWorks_Rework.Models.MeterReadingsViewModel
@{
    ViewData["Title"] = "Meter Readings";
}

<!-- Status Messages -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h4>Meter Readings - @Model.ViewTypeDisplayName</h4>
        <div>
            <button type="button" class="btn btn-outline-primary me-2" id="refreshBtn">
                <i class="bi bi-arrow-clockwise"></i> Refresh
            </button>
            <button type="button" class="btn btn-primary" id="exportBtn">
                <i class="bi bi-download"></i> Export
            </button>
        </div>
    </div>
    <div class="card-body">
        <!-- Tabs Navigation -->
        <ul class="nav nav-tabs mb-4" id="readingsTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link @(Model.ViewType == "raw" ? "active" : "")"
                        id="raw-tab" data-bs-toggle="tab" data-bs-target="#raw-tab-pane"
                        type="button" role="tab" aria-controls="raw-tab-pane"
                        aria-selected="@(Model.ViewType == "raw" ? "true" : "false")"
                        data-view-type="raw">
                    <i class="bi bi-list-ul"></i> Raw Readings
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(Model.ViewType == "daily" ? "active" : "")"
                        id="daily-tab" data-bs-toggle="tab" data-bs-target="#daily-tab-pane"
                        type="button" role="tab" aria-controls="daily-tab-pane"
                        aria-selected="@(Model.ViewType == "daily" ? "true" : "false")"
                        data-view-type="daily">
                    <i class="bi bi-calendar-day"></i> Daily
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(Model.ViewType == "monthly" ? "active" : "")"
                        id="monthly-tab" data-bs-toggle="tab" data-bs-target="#monthly-tab-pane"
                        type="button" role="tab" aria-controls="monthly-tab-pane"
                        aria-selected="@(Model.ViewType == "monthly" ? "true" : "false")"
                        data-view-type="monthly">
                    <i class="bi bi-calendar-month"></i> Monthly
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(Model.ViewType == "yearly" ? "active" : "")"
                        id="yearly-tab" data-bs-toggle="tab" data-bs-target="#yearly-tab-pane"
                        type="button" role="tab" aria-controls="yearly-tab-pane"
                        aria-selected="@(Model.ViewType == "yearly" ? "true" : "false")"
                        data-view-type="yearly">
                    <i class="bi bi-calendar-year"></i> Yearly
                </button>
            </li>
        </ul>

        <!-- Filters Section -->
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h6 class="mb-0">Filters</h6>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3">
                        <label for="meterSelect" class="form-label">Select Meter</label>
                        <select class="form-select" id="meterSelect">
                            <option value="">All Meters</option>
                            @foreach (var meter in Model.AvailableMeters)
                            {
                                <option value="@meter.MeterId"
                                        selected="@(Model.SelectedMeterId == meter.MeterId)">
                                    @meter.FullDisplayName
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label for="startDate" class="form-label">Start Date</label>
                        <input type="datetime-local" class="form-control" id="startDate"
                               value="@(Model.StartDate?.ToString("yyyy-MM-ddTHH:mm"))">
                    </div>
                    <div class="col-md-3">
                        <label for="endDate" class="form-label">End Date</label>
                        <input type="datetime-local" class="form-control" id="endDate"
                               value="@(Model.EndDate?.ToString("yyyy-MM-ddTHH:mm"))">
                    </div>
                    <div class="col-md-3">
                        <label for="pageSize" class="form-label">Page Size</label>
                        <select class="form-select" id="pageSize">
                            <option value="25" selected="@(Model.PageSize == 25)">25</option>
                            <option value="50" selected="@(Model.PageSize == 50)">50</option>
                            <option value="100" selected="@(Model.PageSize == 100)">100</option>
                            <option value="200" selected="@(Model.PageSize == 200)">200</option>
                        </select>
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-md-12 text-end">
                        <button type="button" class="btn btn-outline-secondary me-2" id="clearFiltersBtn">
                            <i class="bi bi-x-circle"></i> Clear Filters
                        </button>
                        <button type="button" class="btn btn-primary" id="applyFiltersBtn">
                            <i class="bi bi-funnel"></i> Apply Filters
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Statistics Panel (shown when meter is selected) -->
        <div id="statsPanel" class="card mb-4" style="@(Model.SelectedMeterId.HasValue ? "" : "display: none;")">
            <div class="card-header bg-info text-white">
                <h6 class="mb-0">
                    <i class="bi bi-graph-up"></i> Statistics for @Model.SelectedMeterName
                </h6>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-2">
                        <div class="text-center">
                            <div class="fs-4 fw-bold text-primary" id="statReadingCount">@Model.MeterStats.ReadingCount</div>
                            <small class="text-muted">Total Readings</small>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="text-center">
                            <div class="fs-4 fw-bold text-success" id="statMinValue">@Model.MeterStats.FormattedMinValue</div>
                            <small class="text-muted">Minimum</small>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="text-center">
                            <div class="fs-4 fw-bold text-warning" id="statAvgValue">@Model.MeterStats.FormattedAvgValue</div>
                            <small class="text-muted">Average</small>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="text-center">
                            <div class="fs-4 fw-bold text-danger" id="statMaxValue">@Model.MeterStats.FormattedMaxValue</div>
                            <small class="text-muted">Maximum</small>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="text-center">
                            <div class="fs-6 fw-bold" id="statFirstReading">@Model.MeterStats.FormattedFirstReading</div>
                            <small class="text-muted">First Reading</small>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="text-center">
                            <div class="fs-6 fw-bold @Model.MeterStats.DataStatusClass" id="statLastReading">@Model.MeterStats.FormattedLastReading</div>
                            <small class="text-muted">Last Reading</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab Content -->
        <div class="tab-content" id="readingsTabContent">
            <!-- All tab panes use the same structure, just different data -->
            <div class="tab-pane fade @(Model.ViewType == "raw" ? "show active" : "")"
                 id="raw-tab-pane" role="tabpanel" aria-labelledby="raw-tab" tabindex="0">
                <div id="readingsContent">
                    @await Html.PartialAsync("_ReadingsTable", Model)
                </div>
            </div>

            <div class="tab-pane fade @(Model.ViewType == "daily" ? "show active" : "")"
                 id="daily-tab-pane" role="tabpanel" aria-labelledby="daily-tab" tabindex="0">
                <div id="readingsContent">
                    @if (Model.ViewType == "daily")
                    {
                        @await Html.PartialAsync("_ReadingsTable", Model)
                    }
                    else
                    {
                        <div class="text-center p-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-2">Loading daily readings...</p>
                        </div>
                    }
                </div>
            </div>

            <div class="tab-pane fade @(Model.ViewType == "monthly" ? "show active" : "")"
                 id="monthly-tab-pane" role="tabpanel" aria-labelledby="monthly-tab" tabindex="0">
                <div id="readingsContent">
                    @if (Model.ViewType == "monthly")
                    {
                        @await Html.PartialAsync("_ReadingsTable", Model)
                    }
                    else
                    {
                        <div class="text-center p-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-2">Loading monthly readings...</p>
                        </div>
                    }
                </div>
            </div>

            <div class="tab-pane fade @(Model.ViewType == "yearly" ? "show active" : "")"
                 id="yearly-tab-pane" role="tabpanel" aria-labelledby="yearly-tab" tabindex="0">
                <div id="readingsContent">
                    @if (Model.ViewType == "yearly")
                    {
                        @await Html.PartialAsync("_ReadingsTable", Model)
                    }
                    else
                    {
                        <div class="text-center p-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-2">Loading yearly readings...</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Remove the duplicate partial render at the bottom -->
@section Scripts {
    <script src="~/js/meter-readings.js" asp-append-version="true"></script>
    <script>
        // Initialize the page
        document.addEventListener('DOMContentLoaded', function() {
            MeterReadings.init({
                currentViewType: '@Model.ViewType',
                selectedMeterId: @(Model.SelectedMeterId?.ToString() ?? "null"),
                currentPage: @Model.CurrentPage,
                pageSize: @Model.PageSize,
                startDate: '@(Model.StartDate?.ToString("yyyy-MM-ddTHH:mm"))',
                endDate: '@(Model.EndDate?.ToString("yyyy-MM-ddTHH:mm"))'
            });
        });
    </script>
}