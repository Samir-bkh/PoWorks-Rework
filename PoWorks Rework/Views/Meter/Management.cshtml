@model PoWorks_Rework.Models.MeterManagementViewModel
@{
    ViewData["Title"] = "Meter Management";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["InfoMessage"] != null)
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        @TempData["InfoMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}


<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h4>Meters</h4>
        
    </div>
    <div class="card-body">
        <!-- Tabs -->
        <ul class="nav nav-tabs mb-4">
            <li class="nav-item">
                <a class="nav-link" asp-controller="Meter" asp-action="Readings">Meter Readings</a>
            </li>
            <li class="nav-item">
                <a class="nav-link active" asp-controller="Meter" asp-action="Management">Meter Management</a>
            </li>
        </ul>

        <!-- Search Area -->
        <form asp-action="Search" method="post">
            <div class="meter-search-area mb-4">
                <div class="row mb-2">
                    <div class="col-md-2">
                        <label for="SearchField" class="form-label">Search Criteria</label>
                    </div>
                    <div class="col-md-4">
                        <select class="form-select" id="SearchField" asp-for="SearchCriteria.SearchField">
                            <option value="Name">Name</option>
                            <option value="Type">Type</option>
                            <option value="Parent">Parent</option>
                            <option value="Tenant">Tenant</option>
                        </select>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-2">
                        <label for="SearchTerm" class="form-label">Search Term</label>
                    </div>
                    <div class="col-md-4">
                        <input type="text" class="form-control" id="SearchTerm" asp-for="SearchCriteria.SearchTerm">
                    </div>
                    <div class="col-md-6 text-end">
                        <button type="submit" class="btn btn-primary me-2">Search</button>
                        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newMeterModal">New Meter</button>
                    </div>
                </div>
            </div>
        </form>

        <!-- Search Results -->
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0">Search Results</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Type</th>
                                <th>Parent</th>
                                <th>Last Reading</th>
                                <th>Unit</th>
                                <th>Tenant</th>
                                <th>Active</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var meter in Model.SearchResults)
                            {
                                <tr class="@(Model.SelectedMeter?.Id == meter.Id ? "table-primary" : "")">
                                    <td><a asp-action="Management" asp-route-id="@meter.Id">@meter.Name</a></td>
                                    <td>@meter.Type</td>
                                    <td>@meter.ParentMeterName</td>
                                    <td>@meter.LastReading</td>
                                    <td>@meter.Unit</td>
                                    <td>@meter.TenantName</td>
                                    <td class="text-center">
                                        @if (meter.Active)
                                        {
                                            <i class="bi bi-check"></i>
                                        }
                                    </td>
                                </tr>
                            }
                            @if (!Model.SearchResults.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center">No meters found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="d-flex justify-content-between align-items-center p-2 bg-light border-top">
                    <div>
                        <nav aria-label="Page navigation">
                            <ul class="pagination mb-0">
                                @if (Model.CurrentPage > 1)
                                {
                                    <li class="page-item">
                                        <a class="page-link" asp-action="Management" asp-route-page="@(Model.CurrentPage - 1)" aria-label="Previous">
                                            <span aria-hidden="true">&laquo;</span>
                                        </a>
                                    </li>
                                }

                                @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                                {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link" asp-action="Management" asp-route-page="@i">@i</a>
                                    </li>
                                }

                                @if (Model.CurrentPage < Model.TotalPages)
                                {
                                    <li class="page-item">
                                        <a class="page-link" asp-action="Management" asp-route-page="@(Model.CurrentPage + 1)" aria-label="Next">
                                            <span aria-hidden="true">&raquo;</span>
                                        </a>
                                    </li>
                                }
                            </ul>
                        </nav>
                    </div>
                    <div>
                        <span class="text-muted">@Model.CurrentPage of @Model.TotalPages pages (@Model.TotalItems items)</span>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.SelectedMeter != null)
        {
            <!-- Meter Details -->
            <form method="post">
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Meter Details</h5>
                    </div>
                    <div class="card-body">
                        <!-- Hidden ID field for the Update action -->
                        <input type="hidden" name="Id" value="@Model.SelectedMeter.Id" />

                        <div class="row mb-3">
                            <div class="col-md-2">
                                <label for="Name" class="form-label">Name</label>
                            </div>
                            <div class="col-md-4">
                                <input type="text" class="form-control" id="Name" name="Name" value="@Model.SelectedMeter.Name">
                                <small class="form-text text-muted">Technical name used internally</small>
                            </div>
                            <div class="col-md-2">
                                <label for="ParentMeterId" class="form-label">Parent</label>
                            </div>
                            <div class="col-md-4">
                                @{
                                    // Pre-determine the selected value to avoid inline conditionals
                                    var parentOptions = new List<SelectListItem>
                            {
                            new SelectListItem { Value = "", Text = "None" }
                            };

                                    foreach (var meter in Model.SearchResults.Where(m => m.Id != Model.SelectedMeter.Id))
                                    {
                                        bool isSelected = meter.Id.ToString() == Model.SelectedMeter.ParentMeterId;
                                        parentOptions.Add(new SelectListItem
                    {
                        Value = meter.Id.ToString(),
                        Text = meter.Name,
                        Selected = isSelected
                    });
                                    }
                                }
                                <select class="form-select" id="ParentMeterId" name="ParentMeterId"
                                        asp-items="parentOptions">
                                </select>
                            </div>
                        </div>

                        <!-- NEW: Label field row -->
                        <div class="row mb-3">
                            <div class="col-md-2">
                                <label for="Label" class="form-label">Label</label>
                            </div>
                            <div class="col-md-4">
                                <input type="text" class="form-control" id="Label" name="Label" value="@Model.SelectedMeter.Label" placeholder="Display name for this meter">
                                <small class="form-text text-muted">Friendly name displayed in the interface</small>
                            </div>
                            <div class="col-md-2">
                                <label for="TenantId" class="form-label">Tenant</label>
                            </div>
                            <div class="col-md-4">
                                <select class="form-select" id="TenantId" name="TenantId" asp-items="Model.TenantOptions">
                                </select>
                                <small class="form-text text-muted">Link this meter to a tenant from the database</small>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-2">
                                <label for="Unit" class="form-label">Unit</label>
                            </div>
                            <div class="col-md-4">
                                <input type="text" class="form-control" id="Unit" name="Unit" value="@Model.SelectedMeter.Unit">
                            </div>
                            <div class="col-md-2">
                                <label for="LastReading" class="form-label">Last Reading</label>
                            </div>
                            <div class="col-md-4">
                                <input type="text" class="form-control" id="LastReading" name="LastReading" value="@Model.SelectedMeter.LastReading">
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-2">
                                <label for="Type" class="form-label">Type</label>
                            </div>
                            <div class="col-md-4">
                                @{
                                    // Pre-determine the selected type value
                                    var typeOptions = new List<SelectListItem>
                            {
                            new SelectListItem { Value = "Main", Text = "Main", Selected = Model.SelectedMeter.Type == "Main" },
                            new SelectListItem { Value = "Sub", Text = "Sub", Selected = Model.SelectedMeter.Type == "Sub" }
                            };
                                }
                                <select class="form-select" id="Type" name="Type"
                                        asp-items="typeOptions">
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label for="Active" class="form-label">Active</label>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check mt-2">
                                    @Html.CheckBox("Active", Model.SelectedMeter.Active, new { @class = "form-check-input" })
                                    <label class="form-check-label" for="Active">
                                        Active
                                    </label>
                                </div>
                            </div>
                        </div>
                        <div class="text-end">
                            <button type="submit" class="btn btn-primary me-2" asp-action="Update">Update</button>
                            <button type="submit" class="btn btn-success" asp-action="Create">Save as New</button>
                        </div>
                    </div>
                </div>
            </form>

            <!-- Sub Meters -->
            <div class="card">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Sub Meters</h5>
                    <div>
                        <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#newSubMeterModal">Add Sub Meter</button>
                    </div>
                </div>
                <div class="card-body">
                    @if (Model.SubMeters.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Type</th>
                                        <th>Last Reading</th>
                                        <th>Unit</th>
                                        <th>Tenant</th>
                                        <th>Active</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var subMeter in Model.SubMeters)
                                    {
                                        <tr>
                                            <td><a asp-action="Management" asp-route-id="@subMeter.Id">@subMeter.Name</a></td>
                                            <td>@subMeter.Type</td>
                                            <td>@subMeter.LastReading</td>
                                            <td>@subMeter.Unit</td>
                                            <td>@subMeter.TenantName</td>
                                            <td class="text-center">
                                                @if (subMeter.Active)
                                                {
                                                    <i class="bi bi-check"></i>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No sub meters found.</p>
                    }
                </div>
            </div>
        }
    </div>
</div>

<!-- New Meter Modal -->
<!-- New Meter Modal (UPDATED) -->
<div class="modal fade" id="newMeterModal" tabindex="-1" aria-labelledby="newMeterModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-action="Create" method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="newMeterModalLabel">New Meter</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label for="Name" class="form-label">Name</label>
                        </div>
                        <div class="col-md-9">
                            <input type="text" class="form-control" id="Name" name="Name" required>
                            <small class="form-text text-muted">Technical name used internally</small>
                        </div>
                    </div>
                    <!-- NEW: Label field -->
                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label for="Label" class="form-label">Label</label>
                        </div>
                        <div class="col-md-9">
                            <input type="text" class="form-control" id="Label" name="Label" placeholder="Display name for this meter">
                            <small class="form-text text-muted">Friendly name displayed in the interface</small>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label for="ParentMeterId" class="form-label">Parent</label>
                        </div>
                        <div class="col-md-9">
                            <select class="form-select" id="ParentMeterId" name="ParentMeterId">
                                <option value="">None</option>
                                @foreach (var meter in Model.SearchResults)
                                {
                                    <option value="@meter.Id">@meter.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <!-- Rest of the modal fields remain the same... -->
                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label for="Unit" class="form-label">Unit</label>
                        </div>
                        <div class="col-md-9">
                            <input type="text" class="form-control" id="Unit" name="Unit">
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label for="LastReading" class="form-label">Last Reading</label>
                        </div>
                        <div class="col-md-9">
                            <input type="text" class="form-control" id="LastReading" name="LastReading" value="0">
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label for="Type" class="form-label">Type</label>
                        </div>
                        <div class="col-md-9">
                            <select class="form-select" id="Type" name="Type">
                                <option value="Main" selected>Main</option>
                                <option value="Sub">Sub</option>
                            </select>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label for="TenantId" class="form-label">Tenant</label>
                        </div>
                        <div class="col-md-9">
                            <select class="form-select" id="TenantId" name="TenantId" asp-items="Model.TenantOptions">
                            </select>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label for="Active" class="form-label">Active</label>
                        </div>
                        <div class="col-md-9">
                            <div class="form-check">
                                @Html.CheckBox("Active", true, new { @class = "form-check-input" })
                                <label class="form-check-label" for="Active">
                                    Active
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>
<!-- New Sub Meter Modal -->
@if (Model.SelectedMeter != null)
{
    <div class="modal fade" id="newSubMeterModal" tabindex="-1" aria-labelledby="newSubMeterModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <form asp-action="Create" method="post">
                    <div class="modal-header">
                        <h5 class="modal-title" id="newSubMeterModalLabel">New Sub Meter</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row mb-3">
                            <div class="col-md-3">
                                <label for="SubMeterName" class="form-label">Name</label>
                            </div>
                            <div class="col-md-9">
                                <input type="text" class="form-control" id="SubMeterName" name="Name" required>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-3">
                                <label for="SubMeterParentId" class="form-label">Parent</label>
                            </div>
                            <div class="col-md-9">
                                <!-- Hidden field with the parent meter ID -->
                                <input type="hidden" id="SubMeterParentId" name="ParentMeterId" value="@Model.SelectedMeter.Id">
                                <input type="text" class="form-control" value="@Model.SelectedMeter.Name" readonly>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-3">
                                <label for="SubMeterUnit" class="form-label">Unit</label>
                            </div>
                            <div class="col-md-9">
                                <input type="text" class="form-control" id="SubMeterUnit" name="Unit">
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-3">
                                <label for="SubMeterLastReading" class="form-label">Last Reading</label>
                            </div>
                            <div class="col-md-9">
                                <input type="text" class="form-control" id="SubMeterLastReading" name="LastReading" value="0">
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-3">
                                <label for="SubMeterType" class="form-label">Type</label>
                            </div>
                            <div class="col-md-9">
                                <!-- Always create as Sub type -->
                                <input type="hidden" name="Type" value="Sub">
                                <input type="text" class="form-control" value="Sub" readonly>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-3">
                                <label for="SubMeterTenantId" class="form-label">Tenant</label>
                            </div>
                            <div class="col-md-9">
                                <select class="form-select" id="SubMeterTenantId" name="TenantId" asp-items="Model.TenantOptions">
                                </select>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-3">
                                <label for="SubMeterActive" class="form-label">Active</label>
                            </div>
                            <div class="col-md-9">
                                <div class="form-check">
                                    @Html.CheckBox("Active", true, new { @class = "form-check-input", id = "SubMeterActive" })
                                    <label class="form-check-label" for="SubMeterActive">
                                        Active
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Create</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}


@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Set the correct selected tenant
            const tenantId = '@Model.SelectedMeter?.TenantId';
            if (tenantId) {
                const tenantSelect = document.getElementById('TenantId');
                if (tenantSelect) {
                    for (let i = 0; i < tenantSelect.options.length; i++) {
                        if (tenantSelect.options[i].value === tenantId) {
                            tenantSelect.options[i].selected = true;
                            break;
                        }
                    }
                }
            }
        });
    </script>
}

@using Microsoft.AspNetCore.Mvc.Rendering