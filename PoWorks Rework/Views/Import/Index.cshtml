@model PoWorks_Rework.Models.ImportExportViewModel
@{
    ViewData["Title"] = "Import/Export";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h4>Import/Export</h4>
    </div>
    <div class="card-body">
        <!-- Tabs -->
        <ul class="nav nav-tabs mb-4" id="importExportTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="import-tab" data-bs-toggle="tab" data-bs-target="#import-tab-pane" type="button" role="tab" aria-controls="import-tab-pane" aria-selected="true">Import</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="export-tab" data-bs-toggle="tab" data-bs-target="#export-tab-pane" type="button" role="tab" aria-controls="export-tab-pane" aria-selected="false">Export</button>
            </li>
        </ul>

        <div class="tab-content" id="importExportTabContent">
            <!-- Import Tab -->
            <div class="tab-pane fade show active" id="import-tab-pane" role="tabpanel" aria-labelledby="import-tab" tabindex="0">
                <div class="row mb-4">
                    <div class="col-md-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title mb-3">Import from PCVue HDS</h5>

                                <!-- SQL Server Connection Selection -->
                                <div class="mb-3">
                                    <label for="hdsConnection" class="form-label">SQL Server Connection</label>
                                    <select class="form-select" id="hdsConnection">
                                        <option value="">Select a connection...</option>
                                    </select>
                                    <div class="form-text">
                                        <span id="connectionStatus" class="text-muted">
                                            <i class="bi bi-info-circle"></i> Select a connection to continue
                                        </span>
                                    </div>
                                </div>

                                <!-- Table Selection -->
                                <div class="mb-3">
                                    <label for="hdsTable" class="form-label">HDS Table</label>
                                    <select class="form-select" id="hdsTable" disabled>
                                        <option value="">Select a table...</option>
                                    </select>
                                    <div class="form-text">Available when connected</div>
                                </div>

                                <!-- Load Meters Button -->
                                <button type="button" class="btn btn-primary" id="loadMetersBtn" disabled>
                                    <i class="bi bi-search"></i> Load Meters
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title mb-3">VAREXP.DAT</h5>

                                <!-- VAREXP Section -->
                                <div class="mb-3">
                                    <label for="varexpFileInput" class="form-label">VAREXP.DAT File</label>
                                    <input class="form-control" type="file" id="varexpFileInput" accept=".dat">
                                </div>
                                <button type="button" class="btn btn-sm btn-secondary" id="parseVarexpBtn">
                                    <i class="bi bi-file-earmark-text"></i> Import VAREXP.DAT
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Web Services Card -->
                    <div class="col-md-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title mb-3">
                                    <i class="bi bi-cloud-download"></i> PCVue Variables Browse
                                </h5>

                                <!-- Web Service Connection Selection -->
                                <div class="mb-3">
                                    <label for="webServiceConnection" class="form-label">Web Service Connection</label>
                                    <select class="form-select" id="webServiceConnection">
                                        <option value="">Select a connection...</option>
                                    </select>
                                    <div class="form-text">
                                        <span id="webServiceConnectionStatus" class="text-muted">
                                            <i class="bi bi-info-circle"></i> Select a web service connection
                                        </span>
                                    </div>
                                </div>

                                <!-- Max Variables Input -->
                                <div class="mb-3">
                                    <label for="maxVariables" class="form-label">Max Variables</label>
                                    <input type="number" class="form-control" id="maxVariables" value="100000" min="1" max="1000000">
                                    <div class="form-text">Maximum variables to retrieve (default: 100,000)</div>
                                </div>

                                <!-- Branch Filter Input -->
                                <div class="mb-3">
                                    <label for="branchFilter" class="form-label">Branch Filter (Optional)</label>
                                    <input type="text" class="form-control" id="branchFilter" placeholder="e.g., Production.Line1">
                                    <div class="form-text">Filter by specific branch/area</div>
                                </div>

                                <!-- Include System Variables Checkbox -->
                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="checkbox" id="includeSystemVariables" value="true">
                                    <label class="form-check-label" for="includeSystemVariables">
                                        <strong>Include System Variables</strong>
                                        <small class="text-muted d-block">By default, variables with 'System' branches are filtered out</small>
                                    </label>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">
                                        <i class="bi bi-calendar-range"></i> Trends Data Range
                                    </label>
                                    <div class="row">
                                        <div class="col-6">
                                            <label for="webServiceStartDate" class="form-label small text-muted">Start Date</label>
                                            <input type="datetime-local" class="form-control form-control-sm" id="webServiceStartDate">
                                        </div>
                                        <div class="col-6">
                                            <label for="webServiceEndDate" class="form-label small text-muted">End Date</label>
                                            <input type="datetime-local" class="form-control form-control-sm" id="webServiceEndDate">
                                        </div>
                                    </div>
                                    <div class="form-text">Select date range for trends data extraction</div>
                                </div>

                                <!-- Quick Date Range Buttons for WebServices -->
                                <div class="mb-3">
                                    <label class="form-label small">Quick Range:</label>
                                    <div class="btn-group btn-group-sm w-100" role="group">
                                        <button type="button" class="btn btn-outline-secondary" id="wsQuickRange24h">24h</button>
                                        <button type="button" class="btn btn-outline-secondary" id="wsQuickRange7d">7 Days</button>
                                        <button type="button" class="btn btn-outline-secondary" id="wsQuickRange30d">30 Days</button>
                                    </div>
                                </div>

                                <!-- Browse Variables Button -->
                                <div class="d-grid gap-2">
                                    <button type="button" class="btn btn-primary" id="browseVariablesBtn" disabled>
                                        <i class="bi bi-search"></i> Browse Variables
                                    </button>
                                </div>

                              

                            

                                <div class="alert alert-info mt-3 mb-0">
                                    <i class="bi bi-info-circle"></i>
                                    <small><strong>Note:</strong> Results are displayed in the server terminal/console for detailed analysis.</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Status Display for Web Services -->
                <div id="webServiceStatus" class="mt-3" style="display: none;"></div>

                <!-- Placeholder for the meter-selection table -->
                <div id="varexpRecordsContainer" class="mt-4"></div>

                <!-- Meter Selection Table (initially hidden) -->
                <div id="meterSelectionSection" class="mt-4 d-none">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">
                                <i class="bi bi-speedometer2"></i> Select Meters to Import
                            </h5>
                            <div class="btn-group" role="group">
                                <button type="button" class="btn btn-outline-primary btn-sm" id="selectAllBtn">
                                    <i class="bi bi-check-all"></i> Select All
                                </button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" id="deselectAllBtn">
                                    <i class="bi bi-x-circle"></i> Deselect All
                                </button>
                            </div>
                        </div>

                        <div class="card-body">
                            <!-- Filter Input -->
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="bi bi-search"></i>
                                        </span>
                                        <input type="text" class="form-control" id="meterFilterInput" placeholder="Filter meters...">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="d-flex align-items-center h-100">
                                        <small class="text-muted" id="meterFilterStatus">Ready to filter meters</small>
                                    </div>
                                </div>
                            </div>

                            <!-- Meters Table Container -->
                            <div class="table-responsive" style="max-height: 400px;">
                                <table class="table table-hover table-sm">
                                    <thead class="table-light sticky-top">
                                        <tr>
                                            <th style="width: 50px;">Import</th>
                                            <th>Meter Name</th>
                                            <th style="width: 120px;">Unit</th>
                                            <th style="width: 100px;">Type</th>
                                            <th style="width: 120px;">Last Reading</th>
                                            <th style="width: 80px;">Active</th>
                                        </tr>
                                    </thead>
                                    <tbody id="metersTableBody">
                                        <!-- Will be populated by JavaScript -->
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="card-footer">
                            <div class="d-flex justify-content-between align-items-center">
                                <!-- Print Button -->
                                <div>
                                    <button type="button" class="btn btn-info" id="printSelectedBtn">
                                        <i class="bi bi-printer"></i> Print Selected
                                    </button>
                                </div>

                                <!-- Import Options -->
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" id="importReadings">
                                    <label class="form-check-label" for="importReadings">
                                        Import historical readings
                                    </label>
                                </div>

                                <!-- Import Button - THIS WILL NOW ALSO PROCESS TRENDS -->
                                <button type="button" class="btn btn-primary" id="importSelectedBtn">
                                    <i class="bi bi-cloud-upload"></i> Import Selected Variables
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Import Result Modal - UPDATED to show trends results -->
                    <div class="modal fade" id="importResultModal" tabindex="-1" aria-labelledby="importResultModalLabel" aria-hidden="true">
                        <div class="modal-dialog modal-lg">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title" id="importResultModalLabel">Import & Trends Results</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <div id="importResultContent"></div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Close</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Export Tab -->
            <div class="tab-pane fade" id="export-tab-pane" role="tabpanel" aria-labelledby="export-tab" tabindex="0">
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">Export Meters</h5>

                        <!-- Export Options -->
                        <div class="mb-3">
                            <label class="form-label">Export Format</label>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="exportFormat" id="exportFormatCsv" value="csv" checked>
                                <label class="form-check-label" for="exportFormatCsv">
                                    CSV
                                </label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="exportFormat" id="exportFormatExcel" value="excel">
                                <label class="form-check-label" for="exportFormatExcel">
                                    Excel
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="exportFormat" id="exportFormatJson" value="json">
                                <label class="form-check-label" for="exportFormatJson">
                                    JSON
                                </label>
                            </div>
                        </div>

                        <!-- Export Filters -->
                        <div class="mb-3">
                            <label class="form-label">Export Filters</label>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="exportActiveOnly" checked>
                                <label class="form-check-label" for="exportActiveOnly">
                                    Active meters only
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="exportWithReadings">
                                <label class="form-check-label" for="exportWithReadings">
                                    Include latest readings
                                </label>
                            </div>
                        </div>

                        <!-- Export Button -->
                        <button type="button" class="btn btn-success" id="exportBtn">
                            <i class="bi bi-download"></i> Export Meters
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
 <script src="~/js/import/hds_import.js"></script>
	<script src="~/js/import/varexp_import.js"></script>
	<script src="~/js/import/webservices_import.js"></script>
    <script src="~/js/import/common.js"></script>
   
}