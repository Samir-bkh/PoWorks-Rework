@model PoWorks_Rework.Models.ImportExportViewModel
@{
    ViewData["Title"] = "Import/Export";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h4>Import/Export</h4>
    </div>
    <div class="card-body">
        <!-- Tabs -->
        <ul class="nav nav-tabs mb-4" id="importExportTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="import-tab" data-bs-toggle="tab" data-bs-target="#import-tab-pane" type="button" role="tab" aria-controls="import-tab-pane" aria-selected="true">Import</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="export-tab" data-bs-toggle="tab" data-bs-target="#export-tab-pane" type="button" role="tab" aria-controls="export-tab-pane" aria-selected="false">Export</button>
            </li>
        </ul>

        <div class="tab-content" id="importExportTabContent">
            <!-- Import Tab -->
            <div class="tab-pane fade show active" id="import-tab-pane" role="tabpanel" aria-labelledby="import-tab" tabindex="0">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title mb-3">Import from PCVue HDS</h5>

                                <!-- SQL Server Connection Selection -->
                                <div class="mb-3">
                                    <label for="hdsConnection" class="form-label">SQL Server Connection</label>
                                    <select class="form-select" id="hdsConnection">
                                        <option value="">Select a connection...</option>
                                    </select>
                                    <div class="form-text">
                                        <span id="connectionStatus" class="text-muted">
                                            <i class="bi bi-info-circle"></i> Select a connection to continue
                                        </span>
                                    </div>
                                </div>

                                <!-- Table Selection -->
                                <div class="mb-3">
                                    <label for="hdsTable" class="form-label">Select HDS Table</label>
                                    <select class="form-select" id="hdsTable" disabled>
                                        <option value="">Select a table...</option>
                                    </select>
                                    <div class="form-text">Choose a connection first to load available tables</div>
                                </div>

                                <!-- Date Range -->
                                <div class="mb-3">
                                    <label class="form-label">Date Range</label>
                                    <div class="row g-2">
                                        <div class="col-6">
                                            <input type="date" class="form-control" id="startDate" placeholder="Start Date">
                                        </div>
                                        <div class="col-6">
                                            <input type="date" class="form-control" id="endDate" placeholder="End Date">
                                        </div>
                                    </div>
                                </div>

                                <!-- Limit -->
                                <div class="mb-3">
                                    <label for="limit" class="form-label">Limit Results</label>
                                    <input type="number" class="form-control" id="limit" value="1000" min="1">
                                    <div class="form-text">Maximum number of meters to retrieve</div>
                                </div>

                                <!-- Load Meters Button -->
                                <div class="d-grid">
                                    <button type="button" class="btn btn-primary" id="loadMetersBtn" disabled>
                                        <i class="bi bi-cloud-download"></i> Load Meters
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title mb-3">Import from CSV / VAREXP.DAT</h5>

                                <!-- CSV Section -->
                                <div class="mb-3">
                                    <label for="csvFile" class="form-label">CSV File</label>
                                    <input class="form-control" type="file" id="csvFile" accept=".csv">
                                </div>
                                <div class="mb-3">
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="checkbox" id="hasHeaders" checked>
                                        <label class="form-check-label" for="hasHeaders">Has headers</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="checkbox" id="skipExistingCsv" checked>
                                        <label class="form-check-label" for="skipExistingCsv">Skip existing meters</label>
                                    </div>
                                </div>
                                <button type="button" class="btn btn-sm btn-primary me-2" id="parseCsvBtn">
                                    <i class="bi bi-filetype-csv"></i> Parse CSV
                                </button>

                                <hr />

                                <!-- VAREXP Section -->
                                <div class="mb-3">
                                    <label for="varexpFileInput" class="form-label">VAREXP.DAT File</label>
                                    <input class="form-control" type="file" id="varexpFileInput" accept=".dat">
                                </div>
                                <button type="button" class="btn btn-sm btn-secondary" id="parseVarexpBtn">
                                    <i class="bi bi-file-earmark-text"></i> Import VAREXP.DAT
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Placeholder for the meter-selection table -->
                    <div id="varexpRecordsContainer" class="mt-4"></div>


                <!-- Meter Selection Table (initially hidden) -->
                <div id="meterSelectionSection" class="d-none">
                    <div class="card mb-4">
                        <div class="card-header bg-light">
                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="mb-0">Meter Selection</h5>
                                <div>
                                    <button type="button" class="btn btn-sm btn-outline-primary me-2" id="selectAllMetersBtn">
                                        <i class="bi bi-check-all"></i> Select All
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" id="deselectAllMetersBtn">
                                        <i class="bi bi-x-lg"></i> Deselect All
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <!-- Filter -->
                            <div class="input-group mb-3">
                                <span class="input-group-text">
                                    <i class="bi bi-search"></i>
                                </span>
                                <input type="text" class="form-control" id="meterFilterInput" placeholder="Filter meters by name...">
                                <span class="input-group-text" id="meterFilterStatus">
                                    Loading meters...
                                </span>
                            </div>

                            <!-- Meters Table -->
                            <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                                <table class="table table-bordered table-hover" id="metersTable">
                                    <thead class="sticky-top bg-light">
                                        <tr>
                                            <th style="width: 50px;" class="text-center">Import</th>
                                            <th>Meter Name</th>
                                            <th>Unit</th>
                                            <th>Parent Meter</th>
                                            <th style="width: 80px;">Type</th>
                                            <th style="width: 80px;">Active</th>
                                        </tr>
                                    </thead>
                                    <tbody id="metersTableBody">
                                        <!-- Will be populated by JavaScript -->
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="card-footer">
                            <div class="d-flex justify-content-between">
                                <button type="button" class="btn btn-success" id="printSelectedBtn">
                                    <i class="bi bi-printer"></i> Print Selected
                                </button>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" id="importReadings">
                                    <label class="form-check-label" for="importReadings">
                                        Import historical readings
                                    </label>
                                </div>
                                <button type="button" class="btn btn-primary" id="importSelectedBtn">
                                    <i class="bi bi-cloud-upload"></i> Import Selected
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Import Progress -->
                    <!-- Import Result Modal -->
                    <div class="modal fade" id="importResultModal" tabindex="-1" aria-labelledby="importResultModalLabel" aria-hidden="true">
                        <div class="modal-dialog modal-lg">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title" id="importResultModalLabel">Import Results</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <div id="importResultContent"></div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Close</button>
                                </div>
                            </div>
                        </div>
                    </div>

            <!-- Export Tab -->
            <div class="tab-pane fade" id="export-tab-pane" role="tabpanel" aria-labelledby="export-tab" tabindex="0">
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">Export Meters</h5>

                        <!-- Export Options -->
                        <div class="mb-3">
                            <label class="form-label">Export Format</label>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="exportFormat" id="exportFormatCsv" value="csv" checked>
                                <label class="form-check-label" for="exportFormatCsv">
                                    CSV
                                </label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="exportFormat" id="exportFormatExcel" value="excel">
                                <label class="form-check-label" for="exportFormatExcel">
                                    Excel
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="exportFormat" id="exportFormatJson" value="json">
                                <label class="form-check-label" for="exportFormatJson">
                                    JSON
                                </label>
                            </div>
                        </div>

                        <!-- Export Filters -->
                        <div class="mb-3">
                            <label class="form-label">Export Filters</label>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="exportAllMeters" checked>
                                <label class="form-check-label" for="exportAllMeters">
                                    Export all meters
                                </label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="exportActiveOnly">
                                <label class="form-check-label" for="exportActiveOnly">
                                    Export active meters only
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="includeReadings">
                                <label class="form-check-label" for="includeReadings">
                                    Include historical readings
                                </label>
                            </div>
                        </div>

                        <!-- Export Button -->
                        <div class="d-grid">
                            <button type="button" class="btn btn-primary" id="exportBtn">
                                <i class="bi bi-download"></i> Export Meters
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

        @section Scripts {
            <script src="~/js/import.js" asp-append-version="true"></script>
                <script src="~/js/hdsMeterImport.js"></script>
        }
