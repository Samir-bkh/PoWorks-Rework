// Views/Tenant/Management.cshtml
@model PoWorks_Rework.Models.TenantViewModel
@{
    ViewData["Title"] = "Tenant Management";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h4>Tenants</h4>
        <div>
            <button type="button" class="btn btn-primary">Import / Export</button>
        </div>
    </div>
    <div class="card-body">
        <!-- Search Area -->
        <div class="search-area bg-light p-3 mb-4">
            <h6>Search</h6>
            <div class="row mb-2">
                <div class="col-md-2">
                    <label for="searchCriteria" class="form-label">Search Criteria</label>
                </div>
                <div class="col-md-3">
                    <select class="form-select" id="searchCriteria" name="SearchCriteria">
                        <option selected>Company Name</option>
                        <option>Contact</option>
                        <option>Email</option>
                        <option>Phone</option>
                    </select>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-2">
                    <label for="searchTerm" class="form-label">Search Term</label>
                </div>
                <div class="col-md-3">
                    <input type="text" class="form-control" id="searchTerm" name="SearchTerm">
                </div>
                <div class="col-md-7 text-end">
                    <button type="button" class="btn btn-primary me-2">Search</button>
                    <button type="button" class="btn btn-primary">New Tenant</button>
                </div>
            </div>
        </div>

        <!-- Search Results -->
        <div class="card mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0">Search Results</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Company</th>
                                <th>Contact</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Outstanding</th>
                                <th>Overdue</th>
                                <th>Active</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="table-primary">
                                <td>PoWorks</td>
                                <td>Abdul</td>
                                <td>ww@cs.com</td>
                                <td>3333333333</td>
                                <td>0</td>
                                <td>0</td>
                                <td class="text-center"><i class="bi bi-check"></i></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="d-flex justify-content-between align-items-center p-2 bg-light border-top">
                    <div>
                        <nav aria-label="Page navigation">
                            <ul class="pagination mb-0">
                                <li class="page-item">
                                    <a class="page-link" href="#" aria-label="First">
                                        <span aria-hidden="true">&laquo;</span>
                                    </a>
                                </li>
                                <li class="page-item active"><a class="page-link" href="#">1</a></li>
                                <li class="page-item">
                                    <a class="page-link" href="#" aria-label="Last">
                                        <span aria-hidden="true">&raquo;</span>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                    <div>
                        <span class="text-muted">1 of 1 pages (1 items)</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabs -->
        <ul class="nav nav-tabs mb-4" id="tenantTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="consumption-tab" data-bs-toggle="tab" data-bs-target="#consumption" type="button" role="tab" aria-controls="consumption" aria-selected="false">Consumption</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="tenant-management-tab" data-bs-toggle="tab" data-bs-target="#tenant-management" type="button" role="tab" aria-controls="tenant-management" aria-selected="true">Tenant Management</button>
            </li>
        </ul>

        <!-- Tab Content -->
        <div class="tab-content" id="tenantTabsContent">
            <!-- Consumption Tab -->
            <div class="tab-pane fade" id="consumption" role="tabpanel" aria-labelledby="consumption-tab">
                <!-- Details Section -->
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Details</h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-2">
                                <label for="overdue" class="form-label">Overdue</label>
                            </div>
                            <div class="col-md-2">
                                <input type="text" class="form-control" id="overdue" name="Overdue" value="0" readonly>
                            </div>
                            <div class="col-md-2">
                                <label for="totalBilledOutstanding" class="form-label">Total Billed Outstanding</label>
                            </div>
                            <div class="col-md-2">
                                <input type="text" class="form-control" id="totalBilledOutstanding" name="TotalBilledOutstanding" value="0" readonly>
                            </div>
                            <div class="col-md-2">
                                <label for="totalMonthUnbilled" class="form-label">Total Month Unbilled</label>
                            </div>
                            <div class="col-md-2">
                                <input type="text" class="form-control" id="totalMonthUnbilled" name="TotalMonthUnbilled" value="0" readonly>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Yearly Comparison Chart -->
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Yearly Comparison</h5>
                    </div>
                    <div class="card-body">
                        <div id="yearlyComparisonChart" style="height: 300px; width: 100%;">
                            <!-- Chart will be placed here -->
                            <p class="text-center text-muted">Yearly comparison chart will be implemented here showing monthly consumption data for the current year, with highlighted values for specific months and tooltips displaying exact values.</p>
                        </div>
                    </div>
                </div>

                <!-- Weekly Comparison Chart -->
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Weekly Comparison</h5>
                    </div>
                    <div class="card-body">
                        <div id="weeklyComparisonChart" style="height: 200px; width: 100%;">
                            <!-- Chart will be placed here -->
                            <p class="text-center text-muted">Weekly comparison chart will be implemented here showing daily consumption values with a line graph, including tooltips for specific dates and their consumption values.</p>
                        </div>
                    </div>
                </div>

                <!-- Meters Section -->
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Meters</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-bordered mb-0">
                                <thead>
                                    <tr>
                                        <th>Meter</th>
                                        <th>Unit</th>
                                        <th>Last Reading</th>
                                        <th>Active</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Meter1000</td>
                                        <td>66666</td>
                                        <td>579652</td>
                                        <td class="text-center"><i class="bi bi-check"></i></td>
                                    </tr>
                                    <tr>
                                        <td>Meter0001</td>
                                        <td>1155</td>
                                        <td>576967</td>
                                        <td class="text-center"><i class="bi bi-check"></i></td>
                                    </tr>
                                    <tr>
                                        <td>Meter0002</td>
                                        <td>812</td>
                                        <td>0</td>
                                        <td class="text-center"><i class="bi bi-check"></i></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <!-- Pagination -->
                        <div class="d-flex justify-content-between align-items-center p-2 bg-light border-top">
                            <div>
                                <nav aria-label="Page navigation">
                                    <ul class="pagination mb-0">
                                        <li class="page-item">
                                            <a class="page-link" href="#" aria-label="First">
                                                <span aria-hidden="true">&laquo;</span>
                                            </a>
                                        </li>
                                        <li class="page-item active"><a class="page-link" href="#">1</a></li>
                                        <li class="page-item">
                                            <a class="page-link" href="#" aria-label="Last">
                                                <span aria-hidden="true">&raquo;</span>
                                            </a>
                                        </li>
                                    </ul>
                                </nav>
                            </div>
                            <div>
                                <span class="text-muted">1 of 1 pages (3 items)</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>


            <!-- Tenant Management Tab -->
            <div class="tab-pane fade show active" id="tenant-management" role="tabpanel" aria-labelledby="tenant-management-tab">
                <!-- Tenant Details -->
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Tenant Details</h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-2">
                                <label for="companyName" class="form-label">Company Name</label>
                            </div>
                            <div class="col-md-4">
                                <input type="text" class="form-control" id="companyName" name="CompanyName" value="PoWorks">
                            </div>
                            <div class="col-md-2">
                                <label for="address1" class="form-label">Address 1</label>
                            </div>
                            <div class="col-md-3">
                                <input type="text" class="form-control" id="address1" name="Address1" value="here">
                            </div>
                            <div class="col-md-1">
                                <label for="unit" class="form-label">Unit</label>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-2">
                                <label for="contact" class="form-label">Contact</label>
                            </div>
                            <div class="col-md-4">
                                <input type="text" class="form-control" id="contact" name="Contact" value="Abdul">
                            </div>
                            <div class="col-md-2">
                                <label for="address2" class="form-label">Address 2</label>
                            </div>
                            <div class="col-md-4">
                                <input type="text" class="form-control" id="address2" name="Address2" value="">
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-2">
                                <label for="email" class="form-label">Email</label>
                            </div>
                            <div class="col-md-4">
                                <input type="email" class="form-control" id="email" name="Email" value="ww@cs.com">
                            </div>
                            <div class="col-md-2">
                                <label for="postCode" class="form-label">Post Code</label>
                            </div>
                            <div class="col-md-4">
                                <input type="text" class="form-control" id="postCode" name="PostCode" value="12345">
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-2">
                                <label for="phone" class="form-label">Phone</label>
                            </div>
                            <div class="col-md-4">
                                <input type="text" class="form-control" id="phone" name="Phone" value="3333333333">
                            </div>
                            <div class="col-md-2">
                                <label for="city" class="form-label">City</label>
                            </div>
                            <div class="col-md-3">
                                <input type="text" class="form-control" id="city" name="City" value="KL">
                            </div>
                            <div class="col-md-1">
                                <div class="form-check mt-2">
                                    <input class="form-check-input" type="checkbox" id="active" name="Active" checked>
                                    <label class="form-check-label" for="active">Active</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tenant Management Section -->
                <div class="card mb-4">
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-2">
                                <label for="startDate" class="form-label">Start Date</label>
                            </div>
                            <div class="col-md-4">
                                <input type="text" class="form-control" id="startDate" name="StartDate" value="2017-5-23">
                            </div>
                            <div class="col-md-1">
                                <label class="form-label">Period</label>
                            </div>
                            <div class="col-md-5">
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="period" id="periodDaily" value="Daily">
                                    <label class="form-check-label" for="periodDaily">Daily</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="period" id="periodWeekly" value="Weekly">
                                    <label class="form-check-label" for="periodWeekly">Weekly</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="period" id="periodMonthly" value="Monthly" checked>
                                    <label class="form-check-label" for="periodMonthly">Monthly</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="period" id="periodQuarterly" value="Quarterly">
                                    <label class="form-check-label" for="periodQuarterly">Quarterly</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="period" id="periodYearly" value="Yearly">
                                    <label class="form-check-label" for="periodYearly">Yearly</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tariff Section -->
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Tariff</h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-1">
                                <label for="tariffType" class="form-label">Type</label>
                            </div>
                            <div class="col-md-3">
                                <select class="form-select" id="tariffType" name="TariffType">
                                    <option selected>Company</option>
                                    <option>Personal</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <input type="text" class="form-control" id="baseRate" name="BaseRate" value="0.5">
                            </div>
                            <div class="col-md-4">
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input type="text" class="form-control" id="baseRateFee" name="BaseRateFee" readonly>
                                </div>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-1">
                                <label for="threshold1" class="form-label">Threshold 1</label>
                            </div>
                            <div class="col-md-3">
                                <input type="text" class="form-control" id="threshold1" name="Threshold1" value="100">
                            </div>
                            <div class="col-md-4">
                                <div class="input-group">
                                    <input type="text" class="form-control" readonly value="kWh">
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="input-group">
                                    <input type="text" class="form-control" id="threshold1Rate" name="Threshold1Rate" value="0.6">
                                    <span class="input-group-text">$</span>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-1">
                                <label for="threshold2" class="form-label">Threshold 2</label>
                            </div>
                            <div class="col-md-3">
                                <input type="text" class="form-control" id="threshold2" name="Threshold2" value="200">
                            </div>
                            <div class="col-md-4">
                                <div class="input-group">
                                    <input type="text" class="form-control" readonly value="kWh">
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="input-group">
                                    <input type="text" class="form-control" id="threshold2Rate" name="Threshold2Rate" value="0.8">
                                    <span class="input-group-text">$</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Other Information Section -->
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Other Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-2">
                                <label for="deposit" class="form-label">Deposit</label>
                            </div>
                            <div class="col-md-3">
                                <div class="input-group">
                                    <input type="text" class="form-control" id="deposit" name="Deposit" value="3500">
                                    <span class="input-group-text">$</span>
                                </div>
                            </div>
                            <div class="col-md-3 offset-md-1">
                                <div class="form-check mt-2">
                                    <input class="form-check-input" type="checkbox" id="emailAlert" name="EmailAlert" checked>
                                    <label class="form-check-label" for="emailAlert">Email Alert</label>
                                </div>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-2">
                                <label for="outstanding" class="form-label">Outstanding</label>
                            </div>
                            <div class="col-md-3">
                                <div class="input-group">
                                    <input type="text" class="form-control" id="outstanding" name="Outstanding" value="0" readonly>
                                    <span class="input-group-text">$</span>
                                </div>
                            </div>
                            <div class="col-md-3 offset-md-1">
                                <div class="form-check mt-2">
                                    <input class="form-check-input" type="checkbox" id="printBill" name="PrintBill" checked>
                                    <label class="form-check-label" for="printBill">Print Bill</label>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-2">
                                <label for="overdue" class="form-label">Overdue</label>
                            </div>
                            <div class="col-md-3">
                                <div class="input-group">
                                    <input type="text" class="form-control" id="overdue" name="Overdue" value="0" readonly>
                                    <span class="input-group-text">$</span>
                                </div>
                            </div>
                            <div class="col-md-3 offset-md-1">
                                <div class="form-check mt-2">
                                    <input class="form-check-input" type="checkbox" id="emailBill" name="EmailBill" checked>
                                    <label class="form-check-label" for="emailBill">Email Bill</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Save Button -->
                <div class="text-end mb-3">
                    <button type="button" class="btn btn-success">Save</button>
                </div>
            </div>
        </div>
    </div>
</div>