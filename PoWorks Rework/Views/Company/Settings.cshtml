// Views/Company/Settings.cshtml (updated to bind to the model)
@model PoWorks_Rework.Models.CompanySettings
@{
    ViewData["Title"] = "Company Settings";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h4>Company Settings</h4>
        <div>
            <button type="submit" form="companySettingsForm" class="btn btn-primary me-2">Save</button>
            <button type="button" class="btn btn-secondary">Cancel</button>
        </div>
    </div>
    <div class="card-body">
        <form id="companySettingsForm" asp-action="SaveSettings" asp-controller="Company" method="post">
            <!-- General Section -->
            <div class="accordion mb-3" id="settingsAccordion">
                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingGeneral">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse"
                                data-bs-target="#collapseGeneral" aria-expanded="true" aria-controls="collapseGeneral">
                            General
                        </button>
                    </h2>
                    <div id="collapseGeneral" class="accordion-collapse collapse show" aria-labelledby="headingGeneral" data-bs-parent="#settingsAccordion">
                        <div class="accordion-body">
                            <div class="row mb-3">
                                <div class="col-md-3">
                                    <label for="DateFormat" class="form-label">Date Format</label>
                                </div>
                                <div class="col-md-9">
                                    <select class="form-select" id="DateFormat" asp-for="DateFormat">
                                        <option value="20-12-2016">20-12-2016</option>
                                        <option value="12-20-2016">12-20-2016</option>
                                        <option value="2016-12-20">2016-12-20</option>
                                    </select>
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-3">
                                    <label for="TimeFormat" class="form-label">Time Format</label>
                                </div>
                                <div class="col-md-9">
                                    <select class="form-select" id="TimeFormat" asp-for="TimeFormat">
                                        <option value="16:01:01">16:01:01</option>
                                        <option value="04:01:01 PM">04:01:01 PM</option>
                                    </select>
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-3">
                                    <label for="ReadingInterval" class="form-label">Reading Interval</label>
                                </div>
                                <div class="col-md-6">
                                    <input type="number" class="form-control" id="ReadingInterval" asp-for="ReadingInterval">
                                </div>
                                <div class="col-md-3">
                                    <span class="form-text mt-2">Times Per Hour</span>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-3">
                                    <label for="OutputFolder" class="form-label">Output Folder</label>
                                </div>
                                <div class="col-md-9">
                                    <input type="text" class="form-control" id="OutputFolder" asp-for="OutputFolder">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Invoice Number Format Section -->
                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingInvoice">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                                data-bs-target="#collapseInvoice" aria-expanded="false" aria-controls="collapseInvoice">
                            Invoice Number Format
                        </button>
                    </h2>
                    <div id="collapseInvoice" class="accordion-collapse collapse" aria-labelledby="headingInvoice" data-bs-parent="#settingsAccordion">
                        <div class="accordion-body">
                            <div class="row mb-3">
                                <div class="col-md-3">
                                    <label for="Prefix" class="form-label">Prefix</label>
                                </div>
                                <div class="col-md-9">
                                    <input type="text" class="form-control" id="Prefix" asp-for="Prefix">
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-3">
                                    <label for="Suffix" class="form-label">Suffix</label>
                                </div>
                                <div class="col-md-9">
                                    <input type="text" class="form-control" id="Suffix" asp-for="Suffix">
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-3">
                                    <label for="NumberOfDigits" class="form-label">Number of Digits</label>
                                </div>
                                <div class="col-md-9">
                                    <input type="number" class="form-control" id="NumberOfDigits" asp-for="NumberOfDigits">
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-3">
                                    <label for="Format" class="form-label">Format</label>
                                </div>
                                <div class="col-md-9">
                                    <input type="text" class="form-control" id="Format" asp-for="Format">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Email Server Section -->
                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingEmail">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                                data-bs-target="#collapseEmail" aria-expanded="false" aria-controls="collapseEmail">
                            Email Server
                        </button>
                    </h2>
                    <div id="collapseEmail" class="accordion-collapse collapse" aria-labelledby="headingEmail" data-bs-parent="#settingsAccordion">
                        <div class="accordion-body">
                            <div class="row mb-3">
                                <div class="col-md-3">
                                    <label for="EmailServer" class="form-label">Email Server</label>
                                </div>
                                <div class="col-md-9">
                                    <input type="text" class="form-control" id="EmailServer" asp-for="EmailServer">
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-3">
                                    <label for="EmailUsername" class="form-label">Username</label>
                                </div>
                                <div class="col-md-9">
                                    <input type="text" class="form-control" id="EmailUsername" asp-for="EmailUsername">
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-3">
                                    <label for="EmailPassword" class="form-label">Password</label>
                                </div>
                                <div class="col-md-9">
                                    <input type="password" class="form-control" id="EmailPassword" asp-for="EmailPassword">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SMS Server Section -->
                <div class="accordion-item">
                    <h2 class="accordion-header" id="headingSMS">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                                data-bs-target="#collapseSMS" aria-expanded="false" aria-controls="collapseSMS">
                            SMS Server
                        </button>
                    </h2>
                    <div id="collapseSMS" class="accordion-collapse collapse" aria-labelledby="headingSMS" data-bs-parent="#settingsAccordion">
                        <div class="accordion-body">
                            <div class="row mb-3">
                                <div class="col-md-3">
                                    <label for="SmsLink" class="form-label">SMS Link</label>
                                </div>
                                <div class="col-md-9">
                                    <input type="text" class="form-control" id="SmsLink" asp-for="SmsLink">
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-3">
                                    <label for="SmsUsername" class="form-label">Username</label>
                                </div>
                                <div class="col-md-9">
                                    <input type="text" class="form-control" id="SmsUsername" asp-for="SmsUsername">
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-3">
                                    <label for="SmsPassword" class="form-label">Password</label>
                                </div>
                                <div class="col-md-9">
                                    <input type="password" class="form-control" id="SmsPassword" asp-for="SmsPassword">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success mt-3">
                    @TempData["SuccessMessage"]
                </div>
            }
        </form>
    </div>
</div>