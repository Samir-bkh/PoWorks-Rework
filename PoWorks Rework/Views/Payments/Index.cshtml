@model PoWorks_Rework.Models.PaymentDashboardViewModel
@{
    ViewData["Title"] = "Payment Dashboard";
}

<div class="container-fluid py-4">
    <h2 class="mb-4">Financial & Payments Dashboard</h2>

    <div class="row mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 16px;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted fw-bold text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                            Revenue Collected
                        </span>
                        <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                            <i class="bi bi-graph-up-arrow fs-5"></i>
                        </div>
                    </div>
                    <h2 class="fw-bolder text-dark mb-1">RM @Model.TotalCollectedThisMonth.ToString("N2")</h2>
                    <span class="text-success fw-medium" style="font-size: 0.85rem;">
                        <i class="bi bi-check2-circle"></i> Successfully processed
                    </span>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 16px;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted fw-bold text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                            Pending Payments
                        </span>
                        <div class="bg-warning bg-opacity-10 text-warning rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                            <i class="bi bi-hourglass-split fs-5"></i>
                        </div>
                    </div>
                    <h2 class="fw-bolder text-dark mb-1">@Model.PendingBillsCount <span class="fs-5 text-muted fw-normal">bill(s)</span></h2>
                    <span class="text-warning text-dark fw-medium" style="font-size: 0.85rem;">
                        <i class="bi bi-clock-history"></i> Validated, awaiting collection
                    </span>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 16px;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted fw-bold text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                            Overdue Payments
                        </span>
                        <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                            <i class="bi bi-exclamation-triangle fs-5"></i>
                        </div>
                    </div>
                    <h2 class="fw-bolder text-dark mb-1">@Model.OverdueBillsCount <span class="fs-5 text-muted fw-normal">bill(s)</span></h2>
                    <span class="text-danger fw-medium" style="font-size: 0.85rem;">
                        <i class="bi bi-shield-exclamation"></i> Action required
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 16px;">
        <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
            <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-journal-check text-primary me-2"></i>Payment History</h5>
        </div>
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="text-muted text-uppercase" style="font-size: 0.75rem; font-weight: 600; letter-spacing: 0.5px;">Payment No.</th>
                            <th class="text-muted text-uppercase" style="font-size: 0.75rem; font-weight: 600; letter-spacing: 0.5px;">Date</th>
                            <th class="text-muted text-uppercase" style="font-size: 0.75rem; font-weight: 600; letter-spacing: 0.5px;">Invoice No.</th>
                            <th class="text-muted text-uppercase" style="font-size: 0.75rem; font-weight: 600; letter-spacing: 0.5px;">Tenant</th>
                            <th class="text-muted text-uppercase text-end" style="font-size: 0.75rem; font-weight: 600; letter-spacing: 0.5px;">Amount Paid</th>
                            <th class="text-muted text-uppercase text-center" style="font-size: 0.75rem; font-weight: 600; letter-spacing: 0.5px;">Method</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.RecentPayments != null && Model.RecentPayments.Any())
                        {
                            foreach (var payment in Model.RecentPayments)
                            {
                                <tr>
                                    <td><span class="fw-medium text-dark">#PAY-@payment.PaymentId.ToString("D4")</span></td>
                                    <td><span class="text-muted">@(payment.PaymentDate?.ToString("dd MMM yyyy") ?? "-")</span></td>
                                    <td>
                                        <a asp-controller="Bills" asp-action="Details" asp-route-id="@payment.BillId" class="text-decoration-none fw-medium">
                                            BILL-@payment.BillId.ToString("D4")
                                        </a>
                                    </td>
                                    <td>@payment.TenantName</td>
                                    <td class="text-end text-success fw-bold">RM @payment.AmountPaid.ToString("N2")</td>
                                    <td class="text-center">
                                        <span class="badge bg-light text-dark border">@payment.PaymentMethod</span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 64px; height: 64px;">
                                        <i class="bi bi-inbox fs-3 opacity-50"></i>
                                    </div>
                                    <p class="mb-0 fw-medium">No payments recorded yet.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>