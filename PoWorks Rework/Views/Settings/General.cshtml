     function getWebServiceToken(connectionId) {
        console.log('Getting OAuth token for connection:', connectionId);

        const form = document.querySelector(`#webservice-${connectionId} form`);
        if (!form) {
            console.error('Form not found for web service connection ID:', connectionId);
            showWebServiceConnectionResult(connectionId, 'danger', 'Error: Could not find form for this connection');
            return;
        }

        // Extract form data
        const formData = new FormData(form);
        const connectionData = {
            connectionId: connectionId,
            connectionName: formData.get('ConnectionName') || '',
            baseUrl: formData.get('BaseUrl') || '',
            clientId: formData.get('ClientId') || '',
            clientSecret: formData.get('ClientSecret') || '',
            username: formData.get('Username') || '',
            password: formData.get('Password') || '',
            timeoutSeconds: parseInt(formData.get('TimeoutSeconds') || '30'),
            projectName: formData.get('ProjectName') || ''
        };

        // Validate required fields
        if (!connectionData.baseUrl || !connectionData.username || !connectionData.password ||
            !connectionData.clientId || !connectionData.clientSecret) {
            showWebServiceConnectionResult(connectionId, 'warning', 'Please fill in all required fields');
            return;
        }

        // Show getting token status
        showWebServiceConnectionResult(connectionId, 'info', 'Getting OAuth token...');

        // Get token via AJAX
        fetch('/Settings/GetWebServiceToken', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(connectionData)
        })
        .then(response => response.json())
        .then(data => {
            console.log('Get token result:', data);
            if (data.success) {
                showWebServiceConnectionResult(connectionId, 'success',
                    `Token acquired successfully! Check server terminal for tokens. Expires in: ${data.expiresIn} seconds`);
            } else {
                showWebServiceConnectionResult(connectionId, 'danger', 'Failed to get token: ' + data.errorMessage);
            }
        })
        .catch(error => {
            console.error('Error getting token:', error);
            showWebServiceConnectionResult(connectionId, 'danger', 'Error getting token: ' + error.message);
        });
    }

