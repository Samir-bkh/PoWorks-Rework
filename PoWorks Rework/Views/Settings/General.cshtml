@model PoWorks_Rework.Models.GeneralSettingsViewModel
@{
    ViewData["Title"] = "Database Connection Settings";
}
<div class="card">
    <div class="card-header">
        <h4>Database Connection Settings</h4>
    </div>
    <div class="card-body">
        <!-- Database Type Tabs -->
        <ul class="nav nav-tabs mb-4" id="databaseTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="postgresql-tab" data-bs-toggle="tab" data-bs-target="#postgresql" type="button" role="tab" aria-controls="postgresql" aria-selected="true">PostgreSQL</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="sqlserver-tab" data-bs-toggle="tab" data-bs-target="#sqlserver" type="button" role="tab" aria-controls="sqlserver" aria-selected="false">SQL Server Connections</button>
            </li>
        </ul>

        <div class="tab-content" id="databaseTabsContent">
            <!-- PostgreSQL Tab -->
            <div class="tab-pane fade show active" id="postgresql" role="tabpanel" aria-labelledby="postgresql-tab">
                <form asp-action="SaveGeneralSettings" asp-controller="Settings" method="post">
                    <div class="accordion" id="settingsAccordion">
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingDatabase">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse"
                                        data-bs-target="#collapseDatabase" aria-expanded="true" aria-controls="collapseDatabase">
                                    PostgreSQL Database Connection
                                </button>
                            </h2>
                            <div id="collapseDatabase" class="accordion-collapse collapse show" aria-labelledby="headingDatabase">
                                <div class="accordion-body">
                                    <div class="mb-3 row">
                                        <label for="PostgreSql_Host" class="col-sm-2 col-form-label">Host</label>
                                        <div class="col-sm-10">
                                            <input type="text" class="form-control" id="PostgreSql_Host" asp-for="PostgreSql.Host" placeholder="localhost">
                                            <div class="form-text">Database server hostname or IP address</div>
                                        </div>
                                    </div>
                                    <div class="mb-3 row">
                                        <label for="PostgreSql_Port" class="col-sm-2 col-form-label">Port</label>
                                        <div class="col-sm-10">
                                            <input type="text" class="form-control" id="PostgreSql_Port" asp-for="PostgreSql.Port" placeholder="5432">
                                            <div class="form-text">PostgreSQL default port is 5432</div>
                                        </div>
                                    </div>
                                    <div class="mb-3 row">
                                        <label for="PostgreSql_Database" class="col-sm-2 col-form-label">Database</label>
                                        <div class="col-sm-10">
                                            <input type="text" class="form-control" id="PostgreSql_Database" asp-for="PostgreSql.Database">
                                            <div class="form-text">Name of the PostgreSQL database (existing or to be created)</div>
                                        </div>
                                    </div>
                                    <div class="mb-3 row">
                                        <label for="PostgreSql_Username" class="col-sm-2 col-form-label">Username</label>
                                        <div class="col-sm-10">
                                            <input type="text" class="form-control" id="PostgreSql_Username" asp-for="PostgreSql.Username" placeholder="postgres">
                                        </div>
                                    </div>
                                    <div class="mb-3 row">
                                        <label for="PostgreSql_Password" class="col-sm-2 col-form-label">Password</label>
                                        <div class="col-sm-10">
                                            <input type="password" class="form-control" id="PostgreSql_Password" asp-for="PostgreSql.Password">
                                        </div>
                                    </div>
                                    <div class="mb-3 row">
                                        <label for="PostgreSql_SSLMode" class="col-sm-2 col-form-label">SSL Mode</label>
                                        <div class="col-sm-10">
                                            <select class="form-select" id="PostgreSql_SSLMode" asp-for="PostgreSql.SSLMode">
                                                <option value="Prefer">Prefer</option>
                                                <option value="Require">Require</option>
                                                <option value="Disable">Disable</option>
                                            </select>
                                            <div class="form-text">Controls PostgreSQL SSL connection behavior</div>
                                        </div>
                                    </div>
                                    <div class="mb-3 row">
                                        <div class="col-sm-10 offset-sm-2">
                                            <button type="button" class="btn btn-outline-primary me-2" id="testConnection">Test Connection</button>
                                            <button type="button" class="btn btn-success" id="connectDatabase">Connect & Create DB</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <!-- SQL Server Tab -->
            <!-- FIND the SQL Server tab content and REPLACE the entire tab-pane with: -->
            <div class="tab-pane fade" id="sqlserver" role="tabpanel" aria-labelledby="sqlserver-tab">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5>SQL Server Connections</h5>
                    <button type="button" class="btn btn-success btn-sm" id="addNewConnection">
                        <i class="bi bi-plus-circle"></i> Add New Connection
                    </button>
                </div>

                <!-- SQL Server Connection Tabs -->
                <ul class="nav nav-pills mb-3" id="sqlServerConnectionTabs" role="tablist">
                    @if (Model.SqlServerConnections.Any())
                    {
                        @for (int i = 0; i < Model.SqlServerConnections.Count; i++)
                        {
                            var connection = Model.SqlServerConnections[i];
                            var isActive = i == 0 ? "active" : "";
                            var isSelected = i == 0 ? "true" : "false";

                            <li class="nav-item" role="presentation">
                                <button class="nav-link @isActive position-relative"
                                        id="sqlconn-@connection.ConnectionId-tab"
                                        data-bs-toggle="pill"
                                        data-bs-target="#sqlconn-@connection.ConnectionId"
                                        type="button"
                                        role="tab"
                                        aria-controls="sqlconn-@connection.ConnectionId"
                                        aria-selected="@isSelected"
                                        data-connection-id="@connection.ConnectionId">
                                    @(!string.IsNullOrEmpty(connection.ConnectionName) ? connection.ConnectionName : $"Connection {i + 1}")
                                    @if (connection.IsDefault)
                                    {
                                        <span class="badge bg-primary ms-1">Default</span>
                                    }
                                    @if (Model.SqlServerConnections.Count > 1)
                                    {
                                        <button type="button" class="btn-close btn-close-sm ms-2" aria-label="Close"
                                                onclick="removeConnection('@connection.ConnectionId')"
                                                style="font-size: 0.6em; margin-left: 8px !important;"></button>
                                    }
                                </button>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active"
                                    id="sqlconn-default-tab"
                                    data-bs-toggle="pill"
                                    data-bs-target="#sqlconn-default"
                                    type="button"
                                    role="tab"
                                    aria-controls="sqlconn-default"
                                    aria-selected="true"
                                    data-connection-id="default">
                                Connection 1
                                <span class="badge bg-primary ms-1">Default</span>
                            </button>
                        </li>
                    }
                </ul>

                <!-- SQL Server Connection Content -->
                <div class="tab-content" id="sqlServerConnectionContent">
                    @if (Model.SqlServerConnections.Any())
                    {
                        @for (int i = 0; i < Model.SqlServerConnections.Count; i++)
                        {
                            var connection = Model.SqlServerConnections[i];
                            var isActive = i == 0 ? "show active" : "";

                            <div class="tab-pane fade @isActive"
                                 id="sqlconn-@connection.ConnectionId"
                                 role="tabpanel"
                                 aria-labelledby="sqlconn-@connection.ConnectionId-tab">

                                <!-- Simple form for now -->
                                <form class="sql-connection-form" data-connection-id="@connection.ConnectionId">
                                    <input type="hidden" name="ConnectionId" value="@connection.ConnectionId" />

                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label class="form-label">Connection Name *</label>
                                                <input type="text" class="form-control" name="ConnectionName" value="@connection.ConnectionName" required />
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label class="form-label">PCVue Project Name</label>
                                                <input type="text" class="form-control" name="ProjectName" value="@connection.ProjectName" />
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-8">
                                            <div class="mb-3">
                                                <label class="form-label">Host *</label>
                                                <input type="text" class="form-control" name="Host" value="@connection.Host" required />
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="mb-3">
                                                <label class="form-label">Port</label>
                                                <input type="text" class="form-control" name="Port" value="@connection.Port" />
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label class="form-label">Database *</label>
                                                <input type="text" class="form-control" name="Database" value="@connection.Database" required />
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label class="form-label">Username *</label>
                                                <input type="text" class="form-control" name="Username" value="@connection.Username" required />
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label class="form-label">Password *</label>
                                                <input type="password" class="form-control" name="Password" value="@connection.Password" required />
                                            </div>
                                        </div>
                                        <div class="col-md-6 text-end">
                                            <button type="button" class="btn btn-outline-primary" onclick="testConnection('@connection.ConnectionId')">
                                                <i class="bi bi-wifi"></i> Test Connection
                                            </button>
                                        </div>
                                    </div>

                                    <div id="connectionResult-@connection.ConnectionId" class="mt-3" style="display: none;"></div>
                                </form>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="tab-pane fade show active" id="sqlconn-default" role="tabpanel" aria-labelledby="sqlconn-default-tab">
                            <p>No SQL Server connections configured. Click "Add New Connection" to create one.</p>
                        </div>
                    }
                </div>

                <!-- Save All Connections Button -->
                <div class="mt-4 text-end">
                    <button type="button" class="btn btn-primary" id="saveAllSqlConnections">
                        <i class="bi bi-save"></i> Save All SQL Server Connections
                    </button>
                </div>
            </div>

        <div class="text-center mt-4">
            <form asp-action="SaveGeneralSettings" asp-controller="Settings" method="post" id="mainSettingsForm">
                <!-- Hidden fields to store values from both tabs -->
                <input type="hidden" name="PostgreSql.Host" id="hidden_PostgreSql_Host" />
                <input type="hidden" name="PostgreSql.Port" id="hidden_PostgreSql_Port" />
                <input type="hidden" name="PostgreSql.Database" id="hidden_PostgreSql_Database" />
                <input type="hidden" name="PostgreSql.Username" id="hidden_PostgreSql_Username" />
                <input type="hidden" name="PostgreSql.Password" id="hidden_PostgreSql_Password" />
                <input type="hidden" name="PostgreSql.SSLMode" id="hidden_PostgreSql_SSLMode" />

                <input type="hidden" name="SqlServer.Host" id="hidden_SqlServer_Host" />
                <input type="hidden" name="SqlServer.Port" id="hidden_SqlServer_Port" />
                <input type="hidden" name="SqlServer.Database" id="hidden_SqlServer_Database" />
                <input type="hidden" name="SqlServer.Username" id="hidden_SqlServer_Username" />
                <input type="hidden" name="SqlServer.Password" id="hidden_SqlServer_Password" />
                <input type="hidden" name="SqlServer.ProjectName" id="hidden_SqlServer_ProjectName" />

                <div class="d-grid gap-2">
                    <button type="button" class="btn btn-primary" id="saveAllSettings">Save All Settings</button>
                </div>
            </form>
        </div>

        <div id="connectionResult" class="alert mt-3" style="display: none;"></div>
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success mt-3">
                @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["WarningMessage"] != null)
        {
            <div class="alert alert-warning mt-3">
                @TempData["WarningMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger mt-3">
                @TempData["ErrorMessage"]
            </div>
        }
    </div>
</div>

<script>

            // Helper function to show messages
        function showMessage(message, type) {
            // Remove any existing alerts
            document.querySelectorAll('.alert-dismissible').forEach(alert => {
                if (alert.textContent.includes('deleted') || alert.textContent.includes('Error')) {
                    alert.remove();
                }
            });

            // Create new alert
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type} alert-dismissible fade show`;
            alertDiv.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            `;

            // Insert at the top of the SQL Server tab content
            const sqlServerTab = document.getElementById('sqlserver');
            if (sqlServerTab) {
                sqlServerTab.insertBefore(alertDiv, sqlServerTab.firstChild);
            }

            // Auto-hide success messages after 3 seconds
            if (type === 'success') {
                setTimeout(() => {
                    if (alertDiv.parentNode) {
                        alertDiv.remove();
                    }
                }, 3000);
            }
        }

        // Helper function to update default badge
        function updateDefaultBadge(newDefaultConnectionId) {
            // Remove all existing default badges
            document.querySelectorAll('#sqlServerConnectionTabs .badge').forEach(badge => {
                if (badge.textContent === 'Default') {
                    badge.remove();
                }
            });

            // Add badge to new default connection
            const newDefaultTab = document.getElementById(`sqlconn-${newDefaultConnectionId}-tab`);
            if (newDefaultTab) {
                const badge = document.createElement('span');
                badge.className = 'badge bg-primary ms-1';
                badge.textContent = 'Default';
                newDefaultTab.appendChild(badge);
            }
        }

            // ADD this to the existing JavaScript section:

        // Add New Connection functionality
        document.getElementById('addNewConnection').addEventListener('click', function() {
            addNewConnection();
        });

        let connectionCounter = @(Model.SqlServerConnections.Count > 0 ? Model.SqlServerConnections.Count : 1);

        function addNewConnection() {
            connectionCounter++;
            const newConnectionId = generateGuid();

            // Create new tab
            const tabsContainer = document.getElementById('sqlServerConnectionTabs');
            const newTabHtml = `
                <li class="nav-item" role="presentation">
                    <button class="nav-link position-relative"
                            id="sqlconn-${newConnectionId}-tab"
                            data-bs-toggle="pill"
                            data-bs-target="#sqlconn-${newConnectionId}"
                            type="button"
                            role="tab"
                            aria-controls="sqlconn-${newConnectionId}"
                            aria-selected="false"
                            data-connection-id="${newConnectionId}">
                        New Connection
                        <button type="button" class="btn-close btn-close-sm ms-2" aria-label="Close"
                                onclick="removeConnection('${newConnectionId}')"
                                style="font-size: 0.6em; margin-left: 8px !important;"></button>
                    </button>
                </li>`;

            tabsContainer.insertAdjacentHTML('beforeend', newTabHtml);

            // Create new content panel
            const contentContainer = document.getElementById('sqlServerConnectionContent');
            const newContentHtml = createConnectionFormHtml(newConnectionId, connectionCounter - 1);
            contentContainer.insertAdjacentHTML('beforeend', newContentHtml);

            // Activate the new tab
            const newTab = document.getElementById(`sqlconn-${newConnectionId}-tab`);
            const newTabInstance = new bootstrap.Tab(newTab);
            newTabInstance.show();
        }

        function createConnectionFormHtml(connectionId, index) {
            return `
                <div class="tab-pane fade" id="sqlconn-${connectionId}" role="tabpanel">
                    <form class="sql-connection-form" data-connection-id="${connectionId}">
                        <input type="hidden" name="ConnectionId" value="${connectionId}" />

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Connection Name *</label>
                                    <input type="text" class="form-control" name="ConnectionName" placeholder="Enter connection name" required />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">PCVue Project Name</label>
                                    <input type="text" class="form-control" name="ProjectName" placeholder="Enter project name" />
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-8">
                                <div class="mb-3">
                                    <label class="form-label">Host *</label>
                                    <input type="text" class="form-control" name="Host" value="localhost" required />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">Port</label>
                                    <input type="text" class="form-control" name="Port" value="1433" />
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Database *</label>
                                    <input type="text" class="form-control" name="Database" placeholder="Database name" required />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Username *</label>
                                    <input type="text" class="form-control" name="Username" required />
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Password *</label>
                                    <input type="password" class="form-control" name="Password" required />
                                </div>
                            </div>
                            <div class="col-md-6 text-end">
                                <button type="button" class="btn btn-outline-primary" onclick="testConnection('${connectionId}')">
                                    <i class="bi bi-wifi"></i> Test Connection
                                </button>
                            </div>
                        </div>

                        <div id="connectionResult-${connectionId}" class="mt-3" style="display: none;"></div>
                    </form>
                </div>`;
        }

        function generateGuid() {
            return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
                var r = Math.random() * 16 | 0, v = c == 'x' ? r : (r & 0x3 | 0x8);
                return v.toString(16);
            });
        }

               window.removeConnection = function(connectionId) {
            // Check if this is the last connection
            const connectionTabs = document.querySelectorAll('#sqlServerConnectionTabs .nav-item');
            if (connectionTabs.length <= 1) {
                alert('Cannot remove the last connection. At least one connection is required.');
                return;
            }

            // Get connection name for confirmation
            const tabButton = document.getElementById(`sqlconn-${connectionId}-tab`);
            const connectionName = tabButton ? tabButton.textContent.replace('×', '').trim() : 'this connection';

            if (confirm(`Are you sure you want to delete "${connectionName}"? This action cannot be undone.`)) {
                // Show loading state
                const resultDiv = document.createElement('div');
                resultDiv.className = 'alert alert-info';
                resultDiv.textContent = 'Deleting connection...';
                document.querySelector('.card-body').appendChild(resultDiv);

                // Call server to delete the connection
                fetch('/Settings/DeleteSqlServerConnection', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ ConnectionId: connectionId })
                })
                .then(response => response.json())
                .then(data => {
                    // Remove loading message
                    resultDiv.remove();

                    if (data.success) {
                        // Remove the tab and content from UI
                        const tabElement = document.getElementById(`sqlconn-${connectionId}-tab`);
                        const contentElement = document.getElementById(`sqlconn-${connectionId}`);

                        if (tabElement) {
                            tabElement.closest('.nav-item').remove();
                        }
                        if (contentElement) {
                            contentElement.remove();
                        }

                        // If no active tab remains, activate the first available tab
                        const remainingTabs = document.querySelectorAll('#sqlServerConnectionTabs .nav-link');
                        if (remainingTabs.length > 0 && !document.querySelector('#sqlServerConnectionTabs .nav-link.active')) {
                            const firstTab = remainingTabs[0];
                            const tabInstance = new bootstrap.Tab(firstTab);
                            tabInstance.show();

                            // If a new default was set, update the badge
                            if (data.newDefaultConnectionId) {
                                updateDefaultBadge(data.newDefaultConnectionId);
                            }
                        }

                        // Show success message
                        showMessage('Connection deleted successfully!', 'success');
                    } else {
                        // Show error message
                        showMessage('Error deleting connection: ' + data.error, 'danger');
                    }
                })
                .catch(error => {
                    // Remove loading message
                    resultDiv.remove();

                    console.error('Error deleting connection:', error);
                    showMessage('Error deleting connection: ' + error.message, 'danger');
                });
            }
        };

        window.testConnection = function(connectionId) {
            const form = document.querySelector(`[data-connection-id="${connectionId}"]`);
            const formData = new FormData(form);
            const connectionData = Object.fromEntries(formData.entries());

            const resultElement = document.getElementById(`connectionResult-${connectionId}`);
            resultElement.style.display = 'block';
            resultElement.className = 'alert alert-info mt-3';
            resultElement.textContent = 'Testing connection...';

            fetch('/Settings/TestSqlServerConnection', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(connectionData)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    resultElement.className = 'alert alert-success mt-3';
                    resultElement.textContent = 'Connection successful!';
                } else {
                    resultElement.className = 'alert alert-danger mt-3';
                    resultElement.textContent = 'Connection failed: ' + data.errorMessage;
                }
            })
            .catch(error => {
                resultElement.className = 'alert alert-danger mt-3';
                resultElement.textContent = 'Error testing connection: ' + error;
            });
        };

        // Save All Connections
        document.getElementById('saveAllSqlConnections').addEventListener('click', function() {
            const forms = document.querySelectorAll('.sql-connection-form');
            const connections = [];

            forms.forEach(form => {
                const formData = new FormData(form);
                const connectionData = Object.fromEntries(formData.entries());
                connections.push(connectionData);
            });

            fetch('/Settings/SaveSqlServerConnections', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ connections: connections })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('SQL Server connections saved successfully!');
                    location.reload();
                } else {
                    alert('Error saving connections: ' + data.error);
                }
            })
            .catch(error => {
                alert('Error saving connections: ' + error);
            });
        });
    document.addEventListener('DOMContentLoaded', function() {
        // PostgreSQL Connection Testing
        document.getElementById('testConnection').addEventListener('click', function() {
            // Get form values
            const connectionData = {
                host: document.getElementById('PostgreSql_Host').value,
                port: document.getElementById('PostgreSql_Port').value,
                database: document.getElementById('PostgreSql_Database').value,
                username: document.getElementById('PostgreSql_Username').value,
                password: document.getElementById('PostgreSql_Password').value,
                sslMode: document.getElementById('PostgreSql_SSLMode').value
            };

            // Test connection via AJAX
            fetch('/Settings/TestConnection', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(connectionData)
            })
            .then(response => response.json())
            .then(data => {
                const resultElement = document.getElementById('connectionResult');
                resultElement.style.display = 'block';

                if (data.success) {
                    resultElement.className = 'alert alert-success mt-3';
                    resultElement.textContent = 'PostgreSQL connection successful!';
                } else {
                    resultElement.className = 'alert alert-danger mt-3';
                    resultElement.textContent = 'PostgreSQL connection failed: ' + data.errorMessage;
                }
            })
            .catch(error => {
                const resultElement = document.getElementById('connectionResult');
                resultElement.style.display = 'block';
                resultElement.className = 'alert alert-danger mt-3';
                resultElement.textContent = 'Error testing connection: ' + error;
            });
        });

        document.getElementById('connectDatabase').addEventListener('click', function() {
            // Get form values
            const connectionData = {
                host: document.getElementById('PostgreSql_Host').value,
                port: document.getElementById('PostgreSql_Port').value,
                database: document.getElementById('PostgreSql_Database').value,
                username: document.getElementById('PostgreSql_Username').value,
                password: document.getElementById('PostgreSql_Password').value,
                sslMode: document.getElementById('PostgreSql_SSLMode').value
            };

            // Call connect endpoint via AJAX
            fetch('/Settings/Connect', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(connectionData)
            })
            .then(response => response.json())
            .then(data => {
                const resultElement = document.getElementById('connectionResult');
                resultElement.style.display = 'block';

                if (data.success) {
                    resultElement.className = 'alert alert-success mt-3';
                    resultElement.textContent = data.message;
                } else {
                    resultElement.className = 'alert alert-danger mt-3';
                    resultElement.textContent = 'Connection failed: ' + data.errorMessage;
                }
            })
            .catch(error => {
                const resultElement = document.getElementById('connectionResult');
                resultElement.style.display = 'block';
                resultElement.className = 'alert alert-danger mt-3';
                resultElement.textContent = 'Error connecting to database: ' + error;
            });
        });

        // SQL Server Connection Testing
        document.getElementById('testSqlServerConnection').addEventListener('click', function() {
            // Get form values
            const connectionData = {
                host: document.getElementById('SqlServer_Host').value,
                port: document.getElementById('SqlServer_Port').value,
                database: document.getElementById('SqlServer_Database').value,
                username: document.getElementById('SqlServer_Username').value,
                password: document.getElementById('SqlServer_Password').value,
                projectName: document.getElementById('SqlServer_ProjectName').value
            };

            // Test connection via AJAX
            fetch('/Settings/TestSqlServerConnection', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(connectionData)
            })
            .then(response => response.json())
            .then(data => {
                const resultElement = document.getElementById('connectionResult');
                resultElement.style.display = 'block';

                if (data.success) {
                    resultElement.className = 'alert alert-success mt-3';
                    resultElement.textContent = 'SQL Server connection successful!';
                } else {
                    resultElement.className = 'alert alert-danger mt-3';
                    resultElement.textContent = 'SQL Server connection failed: ' + data.errorMessage;
                }
            })
            .catch(error => {
                const resultElement = document.getElementById('connectionResult');
                resultElement.style.display = 'block';
                resultElement.className = 'alert alert-danger mt-3';
                resultElement.textContent = 'Error testing SQL Server connection: ' + error;
            });
        });

        // Generate database name from project name
        document.getElementById('generateDbName').addEventListener('click', function() {
            const projectName = document.getElementById('SqlServer_ProjectName').value;
            if (projectName) {
                document.getElementById('SqlServer_Database').value = projectName + '_DB';
            } else {
                alert('Please enter a PCVue Project Name first');
            }
        });

        // Save all settings
        document.getElementById('saveAllSettings').addEventListener('click', function() {
            // Transfer values from visible forms to hidden form fields
            document.getElementById('hidden_PostgreSql_Host').value = document.getElementById('PostgreSql_Host').value;
            document.getElementById('hidden_PostgreSql_Port').value = document.getElementById('PostgreSql_Port').value;
            document.getElementById('hidden_PostgreSql_Database').value = document.getElementById('PostgreSql_Database').value;
            document.getElementById('hidden_PostgreSql_Username').value = document.getElementById('PostgreSql_Username').value;
            document.getElementById('hidden_PostgreSql_Password').value = document.getElementById('PostgreSql_Password').value;
            document.getElementById('hidden_PostgreSql_SSLMode').value = document.getElementById('PostgreSql_SSLMode').value;

            document.getElementById('hidden_SqlServer_Host').value = document.getElementById('SqlServer_Host').value;
            document.getElementById('hidden_SqlServer_Port').value = document.getElementById('SqlServer_Port').value;
            document.getElementById('hidden_SqlServer_Database').value = document.getElementById('SqlServer_Database').value;
            document.getElementById('hidden_SqlServer_Username').value = document.getElementById('SqlServer_Username').value;
            document.getElementById('hidden_SqlServer_Password').value = document.getElementById('SqlServer_Password').value;
            document.getElementById('hidden_SqlServer_ProjectName').value = document.getElementById('SqlServer_ProjectName').value;

            // Submit the form with all settings
            document.getElementById('mainSettingsForm').submit();
        });
    });
</script>