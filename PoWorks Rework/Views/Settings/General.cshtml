@model PoWorks_Rework.Models.GeneralSettingsViewModel
@{
    ViewData["Title"] = "Database Connection Settings";
}
<div class="card">
    <div class="card-header">
        <h4>Database Connection Settings</h4>
    </div>
    <div class="card-body">
        <!-- Database Type Tabs -->
        <ul class="nav nav-tabs mb-4" id="databaseTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="postgresql-tab" data-bs-toggle="tab" data-bs-target="#postgresql" type="button" role="tab" aria-controls="postgresql" aria-selected="true">PostgreSQL</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="sqlserver-tab" data-bs-toggle="tab" data-bs-target="#sqlserver" type="button" role="tab" aria-controls="sqlserver" aria-selected="false">SQL Server Connections</button>
            </li>
            <!-- NEW: Web Services Tab -->
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="webservices-tab" data-bs-toggle="tab" data-bs-target="#webservices" type="button" role="tab" aria-controls="webservices" aria-selected="false">Web Services</button>
            </li>
        </ul>

        <div class="tab-content" id="databaseTabsContent">
            <!-- PostgreSQL Tab -->
            <div class="tab-pane fade show active" id="postgresql" role="tabpanel" aria-labelledby="postgresql-tab">
                <form asp-action="SaveGeneralSettings" asp-controller="Settings" method="post">
                    <div class="accordion" id="settingsAccordion">
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingDatabase">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse"
                                        data-bs-target="#collapseDatabase" aria-expanded="true" aria-controls="collapseDatabase">
                                    PostgreSQL Database Connection
                                </button>
                            </h2>
                            <div id="collapseDatabase" class="accordion-collapse collapse show" aria-labelledby="headingDatabase">
                                <div class="accordion-body">
                                    <div class="mb-3 row">
                                        <label for="PostgreSql_Host" class="col-sm-2 col-form-label">Host</label>
                                        <div class="col-sm-10">
                                            <input type="text" class="form-control" id="PostgreSql_Host" asp-for="PostgreSql.Host" placeholder="localhost">
                                            <div class="form-text">Database server hostname or IP address</div>
                                        </div>
                                    </div>
                                    <div class="mb-3 row">
                                        <label for="PostgreSql_Port" class="col-sm-2 col-form-label">Port</label>
                                        <div class="col-sm-10">
                                            <input type="text" class="form-control" id="PostgreSql_Port" asp-for="PostgreSql.Port" placeholder="5432">
                                            <div class="form-text">PostgreSQL default port is 5432</div>
                                        </div>
                                    </div>
                                    <div class="mb-3 row">
                                        <label for="PostgreSql_Database" class="col-sm-2 col-form-label">Database</label>
                                        <div class="col-sm-10">
                                            <input type="text" class="form-control" id="PostgreSql_Database" asp-for="PostgreSql.Database">
                                            <div class="form-text">Name of the PostgreSQL database (existing or to be created)</div>
                                        </div>
                                    </div>
                                    <div class="mb-3 row">
                                        <label for="PostgreSql_Username" class="col-sm-2 col-form-label">Username</label>
                                        <div class="col-sm-10">
                                            <input type="text" class="form-control" id="PostgreSql_Username" asp-for="PostgreSql.Username" placeholder="postgres">
                                        </div>
                                    </div>
                                    <div class="mb-3 row">
                                        <label for="PostgreSql_Password" class="col-sm-2 col-form-label">Password</label>
                                        <div class="col-sm-10">
                                            <input type="password" class="form-control" id="PostgreSql_Password" asp-for="PostgreSql.Password">
                                        </div>
                                    </div>
                                    <div class="mb-3 row">
                                        <label for="PostgreSql_SSLMode" class="col-sm-2 col-form-label">SSL Mode</label>
                                        <div class="col-sm-10">
                                            <select class="form-select" id="PostgreSql_SSLMode" asp-for="PostgreSql.SSLMode">
                                                <option value="Prefer">Prefer</option>
                                                <option value="Require">Require</option>
                                                <option value="Disable">Disable</option>
                                            </select>
                                            <div class="form-text">Controls PostgreSQL SSL connection behavior</div>
                                        </div>
                                    </div>
                                    <div class="mb-3 row">
                                        <div class="col-sm-10 offset-sm-2">
                                            <button type="button" class="btn btn-outline-primary me-2" id="testConnection">Test Connection</button>
                                            <button type="button" class="btn btn-success" id="connectDatabase">Connect & Create DB</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <!-- SQL Server Tab -->
            <div class="tab-pane fade" id="sqlserver" role="tabpanel" aria-labelledby="sqlserver-tab">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5>SQL Server Connections</h5>
                    <button type="button" class="btn btn-success btn-sm" id="addNewConnection">
                        <i class="bi bi-plus-circle"></i> Add New Connection
                    </button>
                </div>

                <!-- SQL Server Connection Tabs -->
                <ul class="nav nav-pills mb-3" id="sqlServerConnectionTabs" role="tablist">
                    @if (Model.SqlServerConnections.Any())
                    {
                        @for (int i = 0; i < Model.SqlServerConnections.Count; i++)
                        {
                            var connection = Model.SqlServerConnections[i];
                            var isActive = i == 0 ? "active" : "";
                            var isSelected = i == 0 ? "true" : "false";

                            <li class="nav-item" role="presentation">
                                <button class="nav-link @isActive position-relative"
                                        id="sqlconn-@connection.ConnectionId-tab"
                                        data-bs-toggle="pill"
                                        data-bs-target="#sqlconn-@connection.ConnectionId"
                                        type="button"
                                        role="tab"
                                        aria-controls="sqlconn-@connection.ConnectionId"
                                        aria-selected="@isSelected"
                                        data-connection-id="@connection.ConnectionId">
                                    @(!string.IsNullOrEmpty(connection.ConnectionName) ? connection.ConnectionName : $"Connection {i + 1}")
                                    @if (connection.IsDefault)
                                    {
                                        <span class="badge bg-primary ms-1">Default</span>
                                    }
                                    @if (Model.SqlServerConnections.Count > 1)
                                    {
                                        <button type="button" class="btn-close btn-close-sm ms-2" aria-label="Close"
                                                onclick="removeConnection('@connection.ConnectionId')"
                                                style="font-size: 0.6em; margin-left: 8px !important;"></button>
                                    }
                                </button>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active"
                                    id="sqlconn-default-tab"
                                    data-bs-toggle="pill"
                                    data-bs-target="#sqlconn-default"
                                    type="button"
                                    role="tab"
                                    aria-controls="sqlconn-default"
                                    aria-selected="true"
                                    data-connection-id="default">
                                Connection 1
                                <span class="badge bg-primary ms-1">Default</span>
                            </button>
                        </li>
                    }
                </ul>

                <!-- SQL Server Connection Content -->
                <div class="tab-content" id="sqlServerConnectionContent">
                    @if (Model.SqlServerConnections.Any())
                    {
                        @for (int i = 0; i < Model.SqlServerConnections.Count; i++)
                        {
                            var connection = Model.SqlServerConnections[i];
                            var isActive = i == 0 ? "show active" : "";

                            <div class="tab-pane fade @isActive" id="sqlconn-@connection.ConnectionId" role="tabpanel" aria-labelledby="sqlconn-@connection.ConnectionId-tab">
                                <!-- Connection Form -->
                                <form class="sql-connection-form" data-connection-id="@connection.ConnectionId">
                                    <!-- Hidden field for connection ID -->
                                    <input type="hidden" name="ConnectionId" value="@connection.ConnectionId" />

                                    <!-- Connection Name and Default Toggle -->
                                    <div class="row mb-3">
                                        <div class="col-md-8">
                                            <label class="form-label">Connection Name *</label>
                                            <input type="text" class="form-control" name="ConnectionName"
                                                   value="@connection.ConnectionName"
                                                   placeholder="Enter a name for this connection" required />
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-check mt-4">
                                                <input class="form-check-input" type="checkbox" name="IsDefault"
                                                       value="true" @(connection.IsDefault ? "checked" : "")
                                                       id="isDefault-@connection.ConnectionId" />
                                                <label class="form-check-label" for="isDefault-@connection.ConnectionId">
                                                    Set as Default Connection
                                                </label>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Server Details -->
                                    <div class="row mb-3">
                                        <div class="col-md-8">
                                            <label class="form-label">Host/Server *</label>
                                            <input type="text" class="form-control" name="Host"
                                                   value="@connection.Host"
                                                   placeholder="localhost or server IP" required />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label">Port</label>
                                            <input type="text" class="form-control" name="Port"
                                                   value="@connection.Port" placeholder="1433" />
                                        </div>
                                    </div>

                                    <!-- Database and Project -->
                                    <div class="row mb-3">
                                        <div class="col-md-6">
                                            <label class="form-label">Database *</label>
                                            <input type="text" class="form-control" name="Database"
                                                   value="@connection.Database"
                                                   placeholder="Database name" required />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Project Name</label>
                                            <input type="text" class="form-control" name="ProjectName"
                                                   value="@connection.ProjectName"
                                                   placeholder="Optional project association" />
                                        </div>
                                    </div>

                                    <!-- Credentials -->
                                    <div class="row mb-3">
                                        <div class="col-md-6">
                                            <label class="form-label">Username *</label>
                                            <input type="text" class="form-control" name="Username"
                                                   value="@connection.Username"
                                                   placeholder="SQL Server username" required />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Password *</label>
                                            <input type="password" class="form-control" name="Password"
                                                   value="@connection.Password"
                                                   placeholder="SQL Server password" required />
                                        </div>
                                    </div>

                                    <!-- Action Buttons -->
                                    <div class="row">
                                        <div class="col-md-8">
                                            <!-- Connection test result area -->
                                            <div id="connectionResult-@connection.ConnectionId" class="mt-2" style="display: none;"></div>
                                        </div>
                                        <div class="col-md-4 text-end">
                                            <button type="button" class="btn btn-outline-primary"
                                                    onclick="testConnection('@connection.ConnectionId')"
                                                    title="Test this connection">
                                                <i class="bi bi-wifi"></i> Test Connection
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="tab-pane fade show active" id="sqlconn-default" role="tabpanel" aria-labelledby="sqlconn-default-tab">
                            <p>No SQL Server connections configured. Click "Add New Connection" to create one.</p>
                        </div>
                    }
                </div>

                <!-- Save All Connections Button -->
                <div class="mt-4 text-end">
                    <button type="button" class="btn btn-primary" id="saveAllSqlConnections">
                        <i class="bi bi-save"></i> Save All SQL Server Connections
                    </button>
                </div>
            </div>

            <!-- NEW: Web Services Tab -->
            <div class="tab-pane fade" id="webservices" role="tabpanel" aria-labelledby="webservices-tab">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5>PCVue Web Services Connections</h5>
                    <button type="button" class="btn btn-success btn-sm" id="addNewWebServiceConnection">
                        <i class="bi bi-plus-circle"></i> Add New Connection
                    </button>
                </div>

                <!-- Web Service Connection Tabs -->
                <ul class="nav nav-pills mb-3" id="webServiceConnectionTabs" role="tablist">
                    @if (Model.WebServiceConnections != null && Model.WebServiceConnections.Any())
                    {
                        @for (int i = 0; i < Model.WebServiceConnections.Count; i++)
                        {
                            var connection = Model.WebServiceConnections[i];
                            var isActive = i == 0 ? "active" : "";
                            var isSelected = i == 0 ? "true" : "false";

                            <li class="nav-item" role="presentation">
                                <button class="nav-link @isActive position-relative"
                                        id="webservice-@connection.ConnectionId-tab"
                                        data-bs-toggle="pill"
                                        data-bs-target="#webservice-@connection.ConnectionId"
                                        type="button"
                                        role="tab"
                                        aria-controls="webservice-@connection.ConnectionId"
                                        aria-selected="@isSelected"
                                        data-connection-id="@connection.ConnectionId">
                                    @(!string.IsNullOrEmpty(connection.ConnectionName) ? connection.ConnectionName : $"Web Service {i + 1}")
                                    @if (connection.IsDefault)
                                    {
                                        <span class="badge bg-primary ms-1">Default</span>
                                    }
                                    @if (Model.WebServiceConnections.Count > 1)
                                    {
                                        <button type="button" class="btn-close btn-close-sm ms-2" aria-label="Close"
                                                onclick="removeWebServiceConnection('@connection.ConnectionId')"
                                                style="font-size: 0.6em; margin-left: 8px !important;"></button>
                                    }
                                </button>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active"
                                    id="webservice-default-tab"
                                    data-bs-toggle="pill"
                                    data-bs-target="#webservice-default"
                                    type="button"
                                    role="tab"
                                    aria-controls="webservice-default"
                                    aria-selected="true"
                                    data-connection-id="default">
                                Web Service 1
                                <span class="badge bg-primary ms-1">Default</span>
                            </button>
                        </li>
                    }
                </ul>

                <!-- Web Service Connection Content -->
                <div class="tab-content" id="webServiceConnectionContent">
                    @if (Model.WebServiceConnections != null && Model.WebServiceConnections.Any())
                    {
                        @for (int i = 0; i < Model.WebServiceConnections.Count; i++)
                        {
                            var connection = Model.WebServiceConnections[i];
                            var isActive = i == 0 ? "show active" : "";

                            <div class="tab-pane fade @isActive" id="webservice-@connection.ConnectionId" role="tabpanel" aria-labelledby="webservice-@connection.ConnectionId-tab">
                                <form class="webservice-connection-form" data-connection-id="@connection.ConnectionId">
                                    <input type="hidden" name="ConnectionId" value="@connection.ConnectionId" />

                                    <!-- Connection Name and Project Name -->
                                    <div class="row mb-3">
                                        <div class="col-md-8">
                                            <label class="form-label">Connection Name *</label>
                                            <input type="text" class="form-control" name="ConnectionName"
                                                   value="@connection.ConnectionName"
                                                   placeholder="Enter connection name" required />
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-check mt-4">
                                                <input class="form-check-input" type="checkbox" name="IsDefault"
                                                       value="true" @(connection.IsDefault ? "checked" : "")
                                                       id="isDefaultWebService-@connection.ConnectionId" />
                                                <label class="form-check-label" for="isDefaultWebService-@connection.ConnectionId">
                                                    Set as default connection
                                                </label>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row mb-3">
                                        <div class="col-md-6">
                                            <label class="form-label">PCVue Project Name</label>
                                            <input type="text" class="form-control" name="ProjectName"
                                                   value="@connection.ProjectName"
                                                   placeholder="Enter project name" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Timeout (seconds)</label>
                                            <input type="number" class="form-control" name="TimeoutSeconds"
                                                   value="@connection.TimeoutSeconds" min="5" max="300" />
                                        </div>
                                    </div>

                                    <!-- Base URL -->
                                    <div class="row mb-3">
                                        <div class="col-md-12">
                                            <label class="form-label">Base URL *</label>
                                            <input type="url" class="form-control" name="BaseUrl"
                                                   value="@connection.BaseUrl"
                                                   placeholder="https://pcvue-server:8080/api" required />
                                            <small class="form-text text-muted">Full URL to the PCVue Web Services API endpoint</small>
                                        </div>
                                    </div>

                                    <!-- Client ID and Client Secret Fields - Always Visible -->
                                    <div class="row mb-3">
                                        <div class="col-md-6">
                                            <label class="form-label">Client ID</label>
                                            <input type="text" class="form-control" name="ClientId"
                                                   value="@connection.ClientId"
                                                   placeholder="Enter OAuth Client ID" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Client Secret</label>
                                            <input type="password" class="form-control" name="ClientSecret"
                                                   value="@connection.ClientSecret"
                                                   placeholder="Enter OAuth Client Secret" />
                                        </div>
                                    </div>

                                    <!-- Username and Password Fields - Always Visible -->
                                    <div class="row mb-3">
                                        <div class="col-md-6">
                                            <label class="form-label">Username</label>
                                            <input type="text" class="form-control" name="Username"
                                                   value="@connection.Username"
                                                   placeholder="Enter username" />
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Password</label>
                                            <input type="password" class="form-control" name="Password"
                                                   value="@connection.Password"
                                                   placeholder="Enter password" />
                                        </div>
                                    </div>

                                    <!-- Action Buttons -->
                                    <div class="row mt-4">
                                        <div class="col-md-8">
                                            <!-- Connection Test Result -->
                                            <div id="webServiceConnectionResult-@connection.ConnectionId" class="mt-3" style="display: none;"></div>
                                        </div>
                                        <div class="col-md-4 text-end">
                                            <button type="button" class="btn btn-success" onclick="getWebServiceToken('@connection.ConnectionId')">
                                                <i class="bi bi-key"></i> Get Token
                                            </button>
                                            <button type="button" class="btn btn-warning ms-2" onclick="refreshWebServiceToken('@connection.ConnectionId')">
                                                <i class="bi bi-arrow-clockwise"></i> Refresh Token
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="tab-pane fade show active" id="webservice-default" role="tabpanel" aria-labelledby="webservice-default-tab">
                            <p>No Web Service connections configured. Click "Add New Connection" to create one.</p>
                        </div>
                    }
                </div>

                <!-- Save All Web Service Connections Button -->
                <div class="mt-4 text-end">
                    <button type="button" class="btn btn-primary" id="saveAllWebServiceConnections">
                        <i class="bi bi-save"></i> Save All Web Service Connections
                    </button>
                </div>
            </div>

        </div>

        <div id="connectionResult" class="alert mt-3" style="display: none;"></div>
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success mt-3">
                @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["WarningMessage"] != null)
        {
            <div class="alert alert-warning mt-3">
                @TempData["WarningMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger mt-3">
                @TempData["ErrorMessage"]
            </div>
        }
    </div>
</div>

<script>
    // Helper function to show messages
    function showMessage(message, type) {
        // Remove any existing alerts
        document.querySelectorAll('.alert-dismissible').forEach(alert => {
            if (alert.textContent.includes('deleted') || alert.textContent.includes('Error')) {
                alert.remove();
            }
        });

        // Create new alert
        const alertDiv = document.createElement('div');
        alertDiv.className = `alert alert-${type} alert-dismissible fade show`;
        alertDiv.innerHTML = `
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        `;

        // Insert at the top of the current tab content
        const activeTab = document.querySelector('.tab-pane.active');
        if (activeTab) {
            activeTab.insertBefore(alertDiv, activeTab.firstChild);
        }

        // Auto-hide success messages after 3 seconds
        if (type === 'success') {
            setTimeout(() => {
                if (alertDiv.parentNode) {
                    alertDiv.remove();
                }
            }, 3000);
        }
    }

    // Helper function to update default badge
    function updateDefaultBadge(newDefaultConnectionId, tabPrefix = 'sqlconn') {
        // Remove all existing default badges for this tab type
        document.querySelectorAll(`#${tabPrefix === 'sqlconn' ? 'sqlServerConnectionTabs' : 'webServiceConnectionTabs'} .badge`).forEach(badge => {
            if (badge.textContent === 'Default') {
                badge.remove();
            }
        });

        // Add badge to new default connection
        const newDefaultTab = document.getElementById(`${tabPrefix}-${newDefaultConnectionId}-tab`);
        if (newDefaultTab) {
            const badge = document.createElement('span');
            badge.className = 'badge bg-primary ms-1';
            badge.textContent = 'Default';
            newDefaultTab.appendChild(badge);
        }
    }

    // Generate GUID helper
    function generateGuid() {
        return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
            var r = Math.random() * 16 | 0, v = c == 'x' ? r : (r & 0x3 | 0x8);
            return v.toString(16);
        });
    }

    // ================================
    // SQL SERVER CONNECTION FUNCTIONS
    // ================================

    // Add New SQL Server Connection functionality
    document.getElementById('addNewConnection').addEventListener('click', function() {
        addNewConnection();
    });

    let connectionCounter = @(Model.SqlServerConnections.Count > 0 ? Model.SqlServerConnections.Count : 1);

    function addNewConnection() {
        connectionCounter++;
        const newConnectionId = generateGuid();

        // Create new tab
        const tabsContainer = document.getElementById('sqlServerConnectionTabs');
        const newTabHtml = `
            <li class="nav-item" role="presentation">
                <button class="nav-link position-relative"
                        id="sqlconn-${newConnectionId}-tab"
                        data-bs-toggle="pill"
                        data-bs-target="#sqlconn-${newConnectionId}"
                        type="button"
                        role="tab"
                        aria-controls="sqlconn-${newConnectionId}"
                        aria-selected="false"
                        data-connection-id="${newConnectionId}">
                    New Connection
                    <button type="button" class="btn-close btn-close-sm ms-2" aria-label="Close"
                            onclick="removeConnection('${newConnectionId}')"
                            style="font-size: 0.6em; margin-left: 8px !important;"></button>
                </button>
            </li>`;

        tabsContainer.insertAdjacentHTML('beforeend', newTabHtml);

        // Create new content panel
        const contentContainer = document.getElementById('sqlServerConnectionContent');
        const newContentHtml = createConnectionFormHtml(newConnectionId, connectionCounter - 1);
        contentContainer.insertAdjacentHTML('beforeend', newContentHtml);

        // Activate the new tab
        const newTab = document.getElementById(`sqlconn-${newConnectionId}-tab`);
        const newTabInstance = new bootstrap.Tab(newTab);
        newTabInstance.show();
    }

    function createConnectionFormHtml(connectionId, index) {
        return `
            <div class="tab-pane fade" id="sqlconn-${connectionId}" role="tabpanel">
                <form class="sql-connection-form" data-connection-id="${connectionId}">
                    <input type="hidden" name="ConnectionId" value="${connectionId}" />

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Connection Name *</label>
                                <input type="text" class="form-control" name="ConnectionName" placeholder="Enter connection name" required />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">PCVue Project Name</label>
                                <input type="text" class="form-control" name="ProjectName" placeholder="Enter project name" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-8">
                            <div class="mb-3">
                                <label class="form-label">Host *</label>
                                <input type="text" class="form-control" name="Host" value="localhost" required />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label class="form-label">Port</label>
                                <input type="text" class="form-control" name="Port" value="1433" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Database *</label>
                                <input type="text" class="form-control" name="Database" placeholder="Database name" required />
