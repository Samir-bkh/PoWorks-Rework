{
    "DetailedErrors": true,
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Microsoft.Hosting.Lifetime": "Information",
            "PoWorks_Rework.Controllers.MeterController": "Debug"
        },
        "Console": {
            "LogLevel": {
                "Default": "Information",
                "Microsoft": "Warning",
                "PoWorks_Rework.Controllers.MeterController": "Debug"
            },
            "FormatterName": "simple",
            "FormatterOptions": {
                "TimestampFormat": "HH:mm:ss ",
                "UseUtcTimestamp": false,
                "IncludeScopes": false
            }
        }
    }
}